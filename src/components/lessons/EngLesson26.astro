---
// Eng Ch.6 Lesson 4: チェックテスト（クイズ）
---

<div class="max-w-3xl">
  <div id="quiz-container">
    <div id="quiz-content"></div>
  </div>
  <div id="quiz-result" class="hidden">
    <div class="bg-gradient-to-br from-primary-bg to-white rounded-xl p-8 text-center">
      <div class="text-5xl mb-4">🏆</div>
      <h2 class="text-xl font-bold text-gray-900 mb-2">Chapter 6 完了！</h2>
      <p class="text-sm text-gray-600 mb-1">デプロイ・認証・運用 チェックテスト</p>
      <div class="text-3xl font-bold text-primary my-4" id="quiz-score"></div>
      <p class="text-sm text-gray-600 mb-6" id="quiz-message"></p>
      <div class="bg-success-bg rounded-xl p-4 mb-4">
        <p class="text-sm text-success-dark font-medium">コアコース修了！</p>
        <p class="text-xs text-gray-600 mt-1">Ch.1〜6のコアコースを完了しました。上級コース（Ch.7〜9）に進みましょう。</p>
      </div>
      <a href="/track/engineer" class="inline-block px-6 py-2.5 bg-primary text-white rounded-lg text-sm font-medium no-underline hover:bg-primary-dark transition-colors">コースに戻る</a>
    </div>
  </div>
</div>

<script>
  const quizData = [
    { q: "Vercelで自動デプロイを設定する場合、本番環境へのデプロイはどのタイミングで実行されますか？", choices: ["PRを作成したとき", "mainブランチにpushしたとき", "手動でデプロイボタンを押したとき", "テストが全てパスしたとき"], answer: 1, explanation: "Vercelのデフォルト設定では、mainブランチへのpush時に本番デプロイが実行されます。PRごとにはプレビューデプロイが作成されます。" },
    { q: "環境変数の管理で絶対にやってはいけないことは？", choices: [".env.exampleをGitにコミットする", ".envファイルをGitにコミットする", "環境変数にデータベースURLを入れる", "環境別に.envファイルを分ける"], answer: 1, explanation: ".envファイルにはAPIキーやパスワードなどの機密情報が含まれるため、絶対にGitにコミットしてはいけません。.env.exampleは値を空にしたテンプレートなのでコミットして問題ありません。" },
    { q: "NextAuth.jsでセッション管理にJWT方式を選ぶ利点は？", choices: ["セキュリティが最も高い", "サーバーにセッションを保存する必要がない", "パスワードが暗号化される", "OAuth対応になる"], answer: 1, explanation: "JWT方式はトークン自体に認証情報を含むため、サーバー側にセッションストアが不要です。スケーラブルなアプリケーションに適しています。" },
    { q: "Supabaseの Row Level Security（RLS）の役割は？", choices: ["通信の暗号化", "行（レコード）単位でのアクセス制御", "パスワードのハッシュ化", "CORSの設定"], answer: 1, explanation: "RLSはデータベースレベルで行単位のアクセス制御を行う仕組みです。例えば『自分が作成したデータのみ閲覧可能』といったポリシーを設定できます。" },
    { q: "シークレット漏洩を防ぐpre-commitフックの目的は？", choices: ["コードのフォーマットを整える", "テストを自動実行する", "コミット前にシークレットのパターンを検出する", "ブランチ名の命名規則を強制する"], answer: 2, explanation: "pre-commitフックでAPIキーやパスワードのパターンを検出し、うっかりコミットしてしまうのを防ぎます。事後の対応より予防が重要です。" },
  ];

  let currentQ = 0, score = 0;
  const container = document.getElementById('quiz-content');
  const resultDiv = document.getElementById('quiz-result');
  const quizContainer = document.getElementById('quiz-container');

  function renderQuestion() {
    const q = quizData[currentQ];
    container.innerHTML = `
      <div class="mb-2 text-xs text-gray-400">問題 ${currentQ + 1} / ${quizData.length}</div>
      <div class="h-1 bg-base-bar rounded mb-6"><div class="h-1 bg-primary rounded transition-all" style="width:${((currentQ) / quizData.length) * 100}%"></div></div>
      <h2 class="text-base font-semibold text-gray-900 mb-5">${q.q}</h2>
      <div class="space-y-2.5">${q.choices.map((c, i) => `<button class="quiz-choice w-full text-left px-4 py-3 bg-white border border-base-border rounded-xl text-sm hover:border-primary hover:bg-primary-bg transition-all cursor-pointer" data-idx="${i}">${c}</button>`).join('')}</div>
    `;
    container.querySelectorAll('.quiz-choice').forEach(btn => btn.addEventListener('click', () => handleAnswer(Number(btn.dataset.idx))));
  }

  function handleAnswer(idx) {
    const q = quizData[currentQ];
    const correct = idx === q.answer;
    if (correct) score++;
    container.querySelectorAll('.quiz-choice').forEach((btn, i) => {
      btn.disabled = true;
      btn.classList.remove('hover:border-primary', 'hover:bg-primary-bg', 'cursor-pointer');
      if (i === q.answer) { btn.classList.remove('border-base-border', 'bg-white'); btn.classList.add('border-green-500', 'bg-green-50', 'text-green-700'); }
      else if (i === idx && !correct) { btn.classList.remove('border-base-border', 'bg-white'); btn.classList.add('border-red-300', 'bg-red-50', 'text-red-700'); }
    });
    const exp = document.createElement('div');
    exp.className = `mt-4 p-4 rounded-xl text-sm ${correct ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200'}`;
    exp.innerHTML = `<p class="font-medium mb-1">${correct ? '正解！' : '不正解…'}</p><p class="text-xs leading-relaxed">${q.explanation}</p>`;
    container.appendChild(exp);
    const next = document.createElement('button');
    next.className = 'mt-4 w-full py-3 bg-primary text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-primary-dark transition-colors border-none';
    next.textContent = currentQ < quizData.length - 1 ? '次の問題へ' : '結果を見る';
    next.addEventListener('click', () => { currentQ++; currentQ < quizData.length ? renderQuestion() : showResult(); });
    container.appendChild(next);
  }

  function showResult() {
    quizContainer.classList.add('hidden');
    resultDiv.classList.remove('hidden');
    document.getElementById('quiz-score').textContent = `${score} / ${quizData.length} 正解`;
    document.getElementById('quiz-message').textContent = score === quizData.length ? '満点！デプロイ・認証・運用をマスターしました！' : score >= 3 ? 'よくできました！苦手な部分を復習しましょう。' : 'レッスンを復習して再チャレンジしましょう。';
    completeQuiz();
  }

  function completeQuiz() {
    const STORAGE_KEY = 'cca-progress-eng';
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      const data = raw ? { chapters: {}, xp: 0, level: 1, streak: 0, lastStudyDate: null, ...JSON.parse(raw) } : { chapters: {}, xp: 0, level: 1, streak: 0, lastStudyDate: null };
      if (!data.chapters['ch6']) data.chapters['ch6'] = { lessons: {} };
      data.chapters['ch6'].lessons['l4'] = { completed: true, completedAt: new Date().toISOString() };
      data.xp += score * 10;
      data.level = Math.floor(data.xp / 200) + 1;
      const today = new Date().toISOString().slice(0, 10);
      if (data.lastStudyDate !== today) {
        const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
        data.streak = data.lastStudyDate === yesterday ? data.streak + 1 : 1;
        data.lastStudyDate = today;
      }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch(e) {}
  }

  renderQuestion();
</script>
