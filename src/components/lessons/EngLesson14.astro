---
// Eng Ch.4 Lesson 3: チェックテスト（4択クイズ3問）
---

<div class="max-w-3xl">
  <section class="mb-4">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">理解度チェック</h2>
    <p class="text-sm text-gray-600 leading-relaxed mb-6">
      Chapter 4で学んだ内容の確認テストです。全3問に挑戦しましょう。
    </p>
    <div id="quiz-container"></div>
  </section>
</div>

<script>
  const quizData = [
    {
      question: 'PR作成時にClaude Codeに含めるべき情報として最も適切なものは？',
      choices: [
        '変更したファイルの一覧のみ',
        '変更の背景・内容・テスト計画',
        'コミットハッシュとブランチ名',
        '担当者のアサイン情報'
      ],
      correct: 1,
      explanation: 'PR descriptionには「なぜこの変更が必要か（背景）」「何を変更したか（内容）」「どうやって検証するか（テスト計画）」を含めることで、レビュアーが素早くコンテキストを把握できる。Claude Codeはdiffとコミット履歴からこれらを自動生成できる。'
    },
    {
      question: 'ドキュメント自動生成で最も効果的なアプローチは？',
      choices: [
        '既存のコードから仕様を読み取って生成',
        'テンプレートに手動で情報を埋めていく',
        '外部ドキュメントツールで別途管理する',
        'コメントだけ書いてドキュメントは省略する'
      ],
      correct: 0,
      explanation: 'Claude Codeは既存のコード（ルーティング、型定義、コントローラー等）を解析してOpenAPI仕様書やREADMEを生成できる。コードが唯一の真実の源泉（Single Source of Truth）になるため、ドキュメントとコードの乖離が起きにくい。'
    },
    {
      question: 'チーム開発でCLAUDE.mdが重要な理由は？',
      choices: [
        'Claude Codeの動作速度が向上するため',
        'APIキーの管理が簡単になるため',
        'チームメンバー全員が同じ規約でClaude Codeを使えるようになる',
        'GitHubとの連携が自動で設定されるため'
      ],
      correct: 2,
      explanation: 'CLAUDE.mdにコーディング規約・アーキテクチャ方針・テストルールなどを記載しておくと、チームの誰がClaude Codeを使っても同じ品質・スタイルの成果物が得られる。チーム全体の開発品質を均一に保つために重要。'
    }
  ];

  const STORAGE_KEY = 'cca-progress-eng';

  function loadProgress() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      return JSON.parse(raw);
    } catch {
      return null;
    }
  }

  function saveProgress(data) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  }

  function getOrCreateProgress() {
    let data = loadProgress();
    if (!data) {
      data = {
        xp: 0,
        level: 1,
        streak: 0,
        lastStudyDate: null,
        chapters: {}
      };
    }
    if (!data.chapters) data.chapters = {};
    if (!data.chapters.ch4) data.chapters.ch4 = { lessons: {} };
    if (!data.chapters.ch4.lessons) data.chapters.ch4.lessons = {};
    return data;
  }

  function updateStreak(data) {
    const today = new Date().toISOString().split('T')[0];
    if (data.lastStudyDate === today) return;

    if (data.lastStudyDate) {
      const last = new Date(data.lastStudyDate);
      const now = new Date(today);
      const diffDays = Math.floor((now.getTime() - last.getTime()) / (1000 * 60 * 60 * 24));
      if (diffDays === 1) {
        data.streak = (data.streak || 0) + 1;
      } else if (diffDays > 1) {
        data.streak = 1;
      }
    } else {
      data.streak = 1;
    }
    data.lastStudyDate = today;
  }

  function addXP(data, amount) {
    data.xp = (data.xp || 0) + amount;
    data.level = Math.floor(data.xp / 200) + 1;
  }

  // クイズUI
  const container = document.getElementById('quiz-container');
  if (!container) throw new Error('quiz-container not found');

  let currentQ = 0;
  let selectedIdx = -1;
  let correctCount = 0;

  const savedData = getOrCreateProgress();
  const isAlreadyCompleted = savedData.chapters?.ch4?.lessons?.l3?.completed === true;

  if (isAlreadyCompleted) {
    showCompletionScreen();
  } else {
    renderQuestion(currentQ);
  }

  function renderQuestion(qIdx) {
    const q = quizData[qIdx];
    selectedIdx = -1;

    container.innerHTML = `
      <div class="mb-4">
        <div class="flex items-center justify-between mb-4">
          <span class="text-xs text-gray-400">問題 ${qIdx + 1} / ${quizData.length}</span>
          <div class="flex gap-1">
            ${quizData.map((_, i) => `<div class="w-2 h-2 rounded-full ${i < qIdx ? 'bg-primary' : i === qIdx ? 'bg-primary-bg border border-primary-border' : 'bg-gray-200'}"></div>`).join('')}
          </div>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-4">Q${qIdx + 1}. ${q.question}</h3>
        <div class="space-y-2" id="choices">
          ${q.choices.map((c, i) => `
            <button
              class="choice-btn w-full text-left p-4 rounded-xl border border-base-border bg-white text-sm text-gray-700 cursor-pointer hover:bg-base-bg transition-colors"
              data-idx="${i}"
            >
              <span class="inline-block w-6 h-6 rounded-full border border-base-border text-center text-xs leading-6 mr-3 font-medium">${String.fromCharCode(65 + i)}</span>
              ${c}
            </button>
          `).join('')}
        </div>
        <div class="mt-6 flex justify-end">
          <button
            id="submit-btn"
            class="px-6 py-2.5 rounded-lg text-sm font-medium bg-gray-200 text-gray-400 cursor-not-allowed"
            disabled
          >
            解答する
          </button>
        </div>
        <div id="feedback" class="mt-4 hidden"></div>
      </div>
    `;

    container.querySelectorAll('.choice-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.closest('#choices').classList.contains('answered')) return;
        selectedIdx = parseInt(btn.dataset.idx);
        container.querySelectorAll('.choice-btn').forEach(b => {
          b.classList.remove('border-primary-border', 'bg-primary-bg', 'text-primary');
          b.classList.add('border-base-border', 'bg-white', 'text-gray-700');
        });
        btn.classList.remove('border-base-border', 'bg-white', 'text-gray-700');
        btn.classList.add('border-primary-border', 'bg-primary-bg', 'text-primary');

        const submitBtn = document.getElementById('submit-btn');
        submitBtn.disabled = false;
        submitBtn.classList.remove('bg-gray-200', 'text-gray-400', 'cursor-not-allowed');
        submitBtn.classList.add('bg-primary', 'text-white', 'cursor-pointer', 'hover:opacity-90');
      });
    });

    document.getElementById('submit-btn').addEventListener('click', () => {
      if (selectedIdx < 0) return;
      handleAnswer(qIdx, selectedIdx);
    });
  }

  function handleAnswer(qIdx, selIdx) {
    const q = quizData[qIdx];
    const isCorrect = selIdx === q.correct;
    const choicesDiv = document.getElementById('choices');
    choicesDiv.classList.add('answered');

    if (isCorrect) {
      correctCount++;
      const data = getOrCreateProgress();
      addXP(data, 10);
      saveProgress(data);
    }

    container.querySelectorAll('.choice-btn').forEach(btn => {
      const idx = parseInt(btn.dataset.idx);
      btn.classList.remove('cursor-pointer', 'hover:bg-base-bg', 'border-primary-border', 'bg-primary-bg', 'text-primary');
      btn.style.pointerEvents = 'none';

      if (idx === q.correct) {
        btn.classList.remove('border-base-border', 'bg-white', 'text-gray-700');
        btn.classList.add('border-green-300', 'bg-green-50', 'text-green-700');
      } else if (idx === selIdx && !isCorrect) {
        btn.classList.remove('border-base-border', 'bg-white', 'text-gray-700');
        btn.classList.add('border-red-300', 'bg-red-50', 'text-red-600');
      }
    });

    document.getElementById('submit-btn').classList.add('hidden');

    const feedback = document.getElementById('feedback');
    feedback.classList.remove('hidden');
    feedback.innerHTML = `
      <div class="rounded-xl p-4 ${isCorrect ? 'bg-green-50 border border-green-200' : 'bg-red-50 border border-red-200'}">
        <p class="text-sm font-medium ${isCorrect ? 'text-green-700' : 'text-red-600'} mb-1">
          ${isCorrect ? '正解！ XP +10' : '不正解'}
        </p>
        <p class="text-xs ${isCorrect ? 'text-green-600' : 'text-red-500'}">${q.explanation}</p>
      </div>
      <div class="mt-4 flex justify-end">
        <button
          id="next-btn"
          class="px-6 py-2.5 rounded-lg text-sm font-medium bg-primary text-white cursor-pointer hover:opacity-90"
        >
          ${qIdx < quizData.length - 1 ? '次の問題へ' : '結果を見る'}
        </button>
      </div>
    `;

    document.getElementById('next-btn').addEventListener('click', () => {
      if (qIdx < quizData.length - 1) {
        renderQuestion(qIdx + 1);
      } else {
        completeQuiz();
      }
    });
  }

  function completeQuiz() {
    const data = getOrCreateProgress();
    data.chapters.ch4.lessons.l3 = {
      completed: true,
      completedAt: new Date().toISOString()
    };
    updateStreak(data);
    saveProgress(data);

    showCompletionScreen();
  }

  function showCompletionScreen() {
    container.innerHTML = `
      <div class="text-center py-8">
        <div class="text-5xl mb-4">&#127881;</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Ch.4 完了！</h3>
        <p class="text-sm text-gray-600 mb-6">
          Chapter 4「チーム開発・CI/CD連携」をクリアしました。<br>
          次はChapter 5「実践プロジェクト」で総合力を磨きましょう。
        </p>
        <div class="inline-block bg-primary-bg rounded-xl border border-primary-border px-6 py-4 mb-6">
          <div class="flex items-center gap-4">
            <div class="text-center">
              <p class="text-2xl font-bold text-primary">${(() => { const d = getOrCreateProgress(); return d.xp || 0; })()}</p>
              <p class="text-[10px] text-gray-500">合計 XP</p>
            </div>
            <div class="w-px h-10 bg-primary-border"></div>
            <div class="text-center">
              <p class="text-2xl font-bold text-primary">Lv.${(() => { const d = getOrCreateProgress(); return d.level || 1; })()}</p>
              <p class="text-[10px] text-gray-500">レベル</p>
            </div>
            <div class="w-px h-10 bg-primary-border"></div>
            <div class="text-center">
              <p class="text-2xl font-bold text-primary">${(() => { const d = getOrCreateProgress(); return d.streak || 0; })()}日</p>
              <p class="text-[10px] text-gray-500">連続学習</p>
            </div>
          </div>
        </div>
        <p class="text-xs text-gray-400">次のチャプターに進んで、さらにスキルアップしましょう！</p>
      </div>
    `;
  }
</script>
