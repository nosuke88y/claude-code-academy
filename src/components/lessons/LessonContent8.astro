---
// Ch.2 Lesson 4: 動作確認テスト（4択クイズ3問）
---

<div class="max-w-3xl">
  <section class="mb-4">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">動作確認テスト</h2>
    <p class="text-sm text-gray-600 leading-relaxed mb-6">
      Chapter 2で学んだ環境構築の内容を確認しましょう。全3問に挑戦！
    </p>
    <div id="quiz-container"></div>
  </section>
</div>

<script>
  const quizData = [
    {
      question: 'Node.jsをインストールする理由は？',
      choices: ['Webブラウザを高速化するため', 'Claude CodeがNode.js上で動作するため', 'Pythonを使えるようにするため', 'データベースを管理するため'],
      correct: 1,
      explanation: 'Claude CodeはNode.jsで作られたCLIツールです。実行にはNode.jsが必要です。'
    },
    {
      question: 'Claude Codeをインストールするコマンドは？',
      choices: ['pip install claude-code', 'brew install claude', 'npm install -g @anthropic-ai/claude-code', 'apt-get install claude-code'],
      correct: 2,
      explanation: 'Claude Codeはnpmパッケージとして提供されています。-gフラグでグローバルインストールします。'
    },
    {
      question: 'VS CodeでClaude Codeを使う最大のメリットは？',
      choices: ['コードの自動補完が使えるようになる', 'ファイル編集とターミナル操作を同じ画面で行える', 'Claude Codeの料金が無料になる', 'インターネット不要で使えるようになる'],
      correct: 1,
      explanation: 'VS Codeの統合ターミナルを使えば、コードエディタとClaude Codeを同じウィンドウで操作でき、効率的に開発できます。'
    }
  ];

  const STORAGE_KEY = 'cca-progress';
  function loadProgress() { try { const raw = localStorage.getItem(STORAGE_KEY); if (!raw) return null; return JSON.parse(raw); } catch { return null; } }
  function saveProgress(data) { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }
  function getOrCreateProgress() {
    let data = loadProgress();
    if (!data) data = { xp: 0, level: 1, streak: 0, lastStudyDate: null, chapters: {} };
    if (!data.chapters) data.chapters = {};
    if (!data.chapters.ch2) data.chapters.ch2 = { lessons: {} };
    if (!data.chapters.ch2.lessons) data.chapters.ch2.lessons = {};
    return data;
  }
  function updateStreak(data) {
    const today = new Date().toISOString().split('T')[0];
    if (data.lastStudyDate === today) return;
    if (data.lastStudyDate) { const last = new Date(data.lastStudyDate); const now = new Date(today); const diff = Math.floor((now - last) / 86400000); if (diff === 1) data.streak = (data.streak || 0) + 1; else if (diff > 1) data.streak = 1; } else data.streak = 1;
    data.lastStudyDate = today;
  }
  function addXP(data, amount) { data.xp = (data.xp || 0) + amount; data.level = Math.floor(data.xp / 200) + 1; }

  const container = document.getElementById('quiz-container');
  let currentQ = 0, selectedIdx = -1, correctCount = 0;
  const savedData = getOrCreateProgress();
  if (savedData.chapters?.ch2?.lessons?.l4?.completed) { showCompletionScreen(); } else { renderQuestion(0); }

  function renderQuestion(qIdx) {
    const q = quizData[qIdx]; selectedIdx = -1;
    container.innerHTML = `
      <div class="mb-4">
        <div class="flex items-center justify-between mb-4">
          <span class="text-xs text-gray-400">問題 ${qIdx + 1} / ${quizData.length}</span>
          <div class="flex gap-1">${quizData.map((_, i) => `<div class="w-2 h-2 rounded-full ${i < qIdx ? 'bg-primary' : i === qIdx ? 'bg-primary-bg border border-primary-border' : 'bg-gray-200'}"></div>`).join('')}</div>
        </div>
        <h3 class="text-base font-semibold text-gray-900 mb-4">Q${qIdx + 1}. ${q.question}</h3>
        <div class="space-y-2" id="choices">${q.choices.map((c, i) => `<button class="choice-btn w-full text-left p-4 rounded-xl border border-base-border bg-white text-sm text-gray-700 cursor-pointer hover:bg-base-bg transition-colors" data-idx="${i}"><span class="inline-block w-6 h-6 rounded-full border border-base-border text-center text-xs leading-6 mr-3 font-medium">${String.fromCharCode(65 + i)}</span>${c}</button>`).join('')}</div>
        <div class="mt-6 flex justify-end"><button id="submit-btn" class="px-6 py-2.5 rounded-lg text-sm font-medium bg-gray-200 text-gray-400 cursor-not-allowed" disabled>解答する</button></div>
        <div id="feedback" class="mt-4 hidden"></div>
      </div>`;
    container.querySelectorAll('.choice-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.closest('#choices').classList.contains('answered')) return;
        selectedIdx = parseInt(btn.dataset.idx);
        container.querySelectorAll('.choice-btn').forEach(b => { b.classList.remove('border-primary-border','bg-primary-bg','text-primary'); b.classList.add('border-base-border','bg-white','text-gray-700'); });
        btn.classList.remove('border-base-border','bg-white','text-gray-700'); btn.classList.add('border-primary-border','bg-primary-bg','text-primary');
        const s = document.getElementById('submit-btn'); s.disabled = false; s.classList.remove('bg-gray-200','text-gray-400','cursor-not-allowed'); s.classList.add('bg-primary','text-white','cursor-pointer','hover:opacity-90');
      });
    });
    document.getElementById('submit-btn').addEventListener('click', () => { if (selectedIdx < 0) return; handleAnswer(qIdx, selectedIdx); });
  }

  function handleAnswer(qIdx, selIdx) {
    const q = quizData[qIdx]; const isCorrect = selIdx === q.correct;
    document.getElementById('choices').classList.add('answered');
    if (isCorrect) { correctCount++; const data = getOrCreateProgress(); addXP(data, 10); saveProgress(data); }
    container.querySelectorAll('.choice-btn').forEach(btn => {
      const idx = parseInt(btn.dataset.idx); btn.classList.remove('cursor-pointer','hover:bg-base-bg','border-primary-border','bg-primary-bg','text-primary'); btn.style.pointerEvents = 'none';
      if (idx === q.correct) { btn.classList.remove('border-base-border','bg-white','text-gray-700'); btn.classList.add('border-green-300','bg-green-50','text-green-700'); }
      else if (idx === selIdx && !isCorrect) { btn.classList.remove('border-base-border','bg-white','text-gray-700'); btn.classList.add('border-red-300','bg-red-50','text-red-600'); }
    });
    document.getElementById('submit-btn').classList.add('hidden');
    const feedback = document.getElementById('feedback'); feedback.classList.remove('hidden');
    feedback.innerHTML = `
      <div class="rounded-xl p-4 ${isCorrect ? 'bg-green-50 border border-green-200' : 'bg-red-50 border border-red-200'}">
        <p class="text-sm font-medium ${isCorrect ? 'text-green-700' : 'text-red-600'} mb-1">${isCorrect ? '⭕ 正解！ XP +10' : '❌ 不正解'}</p>
        <p class="text-xs ${isCorrect ? 'text-green-600' : 'text-red-500'}">${q.explanation}</p>
      </div>
      <div class="mt-4 flex justify-end"><button id="next-btn" class="px-6 py-2.5 rounded-lg text-sm font-medium bg-primary text-white cursor-pointer hover:opacity-90">${qIdx < quizData.length - 1 ? '次の問題へ →' : '結果を見る →'}</button></div>`;
    document.getElementById('next-btn').addEventListener('click', () => { if (qIdx < quizData.length - 1) renderQuestion(qIdx + 1); else completeQuiz(); });
  }

  function completeQuiz() {
    const data = getOrCreateProgress();
    data.chapters.ch2.lessons.l4 = { completed: true, completedAt: new Date().toISOString() };
    updateStreak(data); saveProgress(data); showCompletionScreen();
  }

  function showCompletionScreen() {
    container.innerHTML = `
      <div class="text-center py-8">
        <div class="text-5xl mb-4">🎉</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Ch.2 完了！</h3>
        <p class="text-sm text-gray-600 mb-6">おめでとうございます！環境構築をマスターしました。</p>
        <div class="inline-block bg-primary-bg rounded-xl border border-primary-border px-6 py-4 mb-6">
          <div class="flex items-center gap-4">
            <div class="text-center"><p class="text-2xl font-bold text-primary">${(() => { const d = getOrCreateProgress(); return d.xp || 0; })()}</p><p class="text-[10px] text-gray-500">合計 XP</p></div>
            <div class="w-px h-10 bg-primary-border"></div>
            <div class="text-center"><p class="text-2xl font-bold text-primary">Lv.${(() => { const d = getOrCreateProgress(); return d.level || 1; })()}</p><p class="text-[10px] text-gray-500">レベル</p></div>
            <div class="w-px h-10 bg-primary-border"></div>
            <div class="text-center"><p class="text-2xl font-bold text-primary">${(() => { const d = getOrCreateProgress(); return d.streak || 0; })()}日</p><p class="text-[10px] text-gray-500">連続学習</p></div>
          </div>
        </div>
        <p class="text-xs text-gray-400">次はCh.3「基本コマンドとプロンプト設計」に進みましょう！</p>
      </div>`;
  }
</script>
