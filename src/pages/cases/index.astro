---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
---

<Layout title="活用事例集 — Claude Code Academy">
  <Sidebar currentPage="cases" />
  <main class="ml-[260px] p-8 min-h-screen">
    <div class="mb-7">
      <h1 class="text-[22px] font-semibold text-gray-900">活用事例集</h1>
      <p class="text-sm text-gray-400 mt-1">実際の企業・個人によるClaude Code活用事例 · Web検索で収集</p>
    </div>

    <div class="grid grid-cols-4 gap-3.5 mb-7">
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5"><div class="text-xs text-gray-400 mb-0.5">事例数</div><div class="text-lg font-semibold text-gray-900" id="s-total">0</div></div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5"><div class="text-xs text-gray-400 mb-0.5">表示中</div><div class="text-lg font-semibold text-primary" id="s-show">0</div></div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5"><div class="text-xs text-gray-400 mb-0.5">平均削減率</div><div class="text-lg font-semibold text-success-dark" id="s-avg">0%</div></div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5"><div class="text-xs text-gray-400 mb-0.5">海外事例</div><div class="text-lg font-semibold text-blue-600" id="s-intl">0</div></div>
    </div>

    <div class="bg-white rounded-[10px] border border-base-border p-4 mb-5">
      <div class="flex items-center gap-3 mb-3">
        <input type="text" id="search" placeholder="キーワードで検索..." class="flex-1 px-3 py-2 border border-base-border rounded-lg text-sm focus:outline-none focus:border-primary" />
        <select id="sort" class="px-3 py-2 border border-base-border rounded-lg text-xs bg-white cursor-pointer">
          <option value="new">新しい順</option>
          <option value="old">古い順</option>
          <option value="pct">削減率順</option>
        </select>
      </div>
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[11px] text-gray-400 w-16 shrink-0">カテゴリ:</span>
        <button class="cf active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="all">すべて</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="dev">開発効率化</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="auto">業務自動化</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="data">データ分析</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="content">コンテンツ</button>
      </div>
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[11px] text-gray-400 w-16 shrink-0">職種:</span>
        <button class="jf active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="all">すべて</button>
        <button class="jf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="eng">エンジニア</button>
        <button class="jf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="biz">ビジネス職</button>
        <button class="jf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="non">非エンジニア</button>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[11px] text-gray-400 w-16 shrink-0">難易度:</span>
        <button class="lf active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="all">すべて</button>
        <button class="lf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="初級">初級</button>
        <button class="lf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="中級">中級</button>
        <button class="lf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="上級">上級</button>
      </div>
    </div>

    <div id="list" class="grid grid-cols-1 gap-3"></div>
    <div id="empty" class="hidden text-center py-16"><p class="text-sm text-gray-400">条件に一致する事例がありません</p></div>
  </main>
</Layout>

<style>
  .cf.active,.jf.active,.lf.active{background-color:var(--color-primary-bg);color:var(--color-primary);border-color:var(--color-primary-border)}
  .cf:not(.active),.jf:not(.active),.lf:not(.active){background-color:white;color:#6b7280;border-color:var(--color-base-border)}
</style>

