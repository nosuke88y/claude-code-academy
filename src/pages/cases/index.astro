const CL={"dev":"開発効率化","auto":"業務自動化","data":"データ分析","content":"コンテンツ"};
const CC={"dev":"bg-blue-100 text-blue-700","auto":"bg-green-100 text-green-700","data":"bg-purple-100 text-purple-700","content":"bg-orange-100 text-orange-700"};
const JL={"eng":"エンジニア","biz":"ビジネス職","non":"非エンジニア"};
const JC={"eng":"bg-yellow-50 text-yellow-700","biz":"bg-primary-bg text-primary","non":"bg-pink-50 text-pink-700"};
const LC={"初級":"bg-green-100 text-green-700","中級":"bg-blue-100 text-blue-700","上級":"bg-purple-100 text-purple-700"};
let fC='all',fJ='all',fL='all',q='',srt='new';

function render(){
  let f=D.filter(c=>{
    if(fC!=='all'&&c.cat!==fC)return false;if(fJ!=='all'&&c.job!==fJ)return false;if(fL!=='all'&&c.lv!==fL)return false;
    if(q){const s=q.toLowerCase();return c.t.toLowerCase().includes(s)||c.b.toLowerCase().includes(s)||c.h.toLowerCase().includes(s)||c.a.toLowerCase().includes(s)||c.src.toLowerCase().includes(s);}
    return true;
  });
  if(srt==='new')f.sort((a,b)=>b.dt.localeCompare(a.dt));
  else if(srt==='old')f.sort((a,b)=>a.dt.localeCompare(b.dt));
  else if(srt==='pct')f.sort((a,b)=>b.p-a.p);

  document.getElementById('s-total').textContent=D.length;
  document.getElementById('s-show').textContent=f.length;
  const avg=Math.round(D.reduce((s,c)=>s+c.p,0)/D.length);
  document.getElementById('s-avg').textContent=avg+'%';
  document.getElementById('s-intl').textContent=D.filter(c=>c.intl).length;

  const el=document.getElementById('list'),no=document.getElementById('empty');
  if(!f.length){el.innerHTML='';no.classList.remove('hidden');return;}
  no.classList.add('hidden');
  el.innerHTML=f.map(c=>`<a href="/cases/case-${c.id}" class="block bg-white rounded-[10px] border border-base-border p-5 hover:border-primary-pale hover:shadow-[0_2px_8px_rgba(83,74,183,0.08)] transition-all no-underline">
    <div class="flex items-start justify-between gap-3 mb-2">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-[10px] px-2 py-0.5 rounded-full ${CC[c.cat]}">${CL[c.cat]}</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full ${JC[c.job]}">${JL[c.job]}</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full ${LC[c.lv]}">${c.lv}</span>
        <span class="text-[10px] text-gray-400">${c.dt}</span>
      </div>
      ${c.p?`<div class="text-lg font-bold text-success-dark shrink-0">-${c.p}%</div>`:''}
    </div>
    <h3 class="text-sm font-semibold text-gray-900 mb-2">${c.t}</h3>
    <div class="grid grid-cols-[1fr_auto_1fr] gap-2 mb-2 text-xs">
      <div class="bg-red-50 rounded-lg p-2 border border-red-100"><div class="text-[10px] text-red-400 font-medium mb-0.5">Before</div><div class="text-gray-700">${c.b}</div></div>
      <div class="flex items-center text-gray-300">→</div>
      <div class="bg-green-50 rounded-lg p-2 border border-green-100"><div class="text-[10px] text-green-500 font-medium mb-0.5">After</div><div class="text-gray-700 font-medium">${c.a}</div></div>
    </div>
    <div class="flex items-center gap-1 flex-wrap">
      ${c.tags.map(tag=>`<span class="text-[9px] px-1.5 py-0.5 rounded bg-base-muted text-gray-500">${tag}</span>`).join('')}
      <span class="text-[10px] text-gray-400 ml-1">${c.src}</span>
      ${c.intl?'<span class="text-[9px] px-1.5 py-0.5 rounded bg-blue-50 text-blue-600 ml-auto">海外</span>':''}
    </div>
  </a>`).join('');
}

document.querySelectorAll('.cf').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.cf').forEach(x=>x.classList.remove('active'));b.classList.add('active');fC=b.dataset.v;render();});});
document.querySelectorAll('.jf').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.jf').forEach(x=>x.classList.remove('active'));b.classList.add('active');fJ=b.dataset.v;render();});});
document.querySelectorAll('.lf').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.lf').forEach(x=>x.classList.remove('active'));b.classList.add('active');fL=b.dataset.v;render();});});
document.getElementById('sort').addEventListener('change',e=>{srt=e.target.value;render();});
let st;document.getElementById('search').addEventListener('input',e=>{clearTimeout(st);st=setTimeout(()=>{q=e.target.value.trim();render();},200);});
render();
</script>
