---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import fukugyou from '../../data/cases/fukugyou.json';
import kojin_dev from '../../data/cases/kojin_dev.json';
import hongyou from '../../data/cases/hongyou.json';
import toushi from '../../data/cases/toushi.json';
import kigyou from '../../data/cases/kigyou.json';

const ALL_CASES = [...fukugyou, ...kojin_dev, ...hongyou, ...toushi, ...kigyou];
const allCasesJson = JSON.stringify(ALL_CASES);
---

<Layout title="活用事例集 — Claude Code Academy">
  <Sidebar currentPage="cases" />
  <main class="ml-[260px] p-8 min-h-screen">
    <div class="mb-7">
      <h1 class="text-[22px] font-semibold text-gray-900">活用事例集</h1>
      <p class="text-sm text-gray-400 mt-1">Claude/Claude Codeで実現できる150の個人向けハウツー</p>
    </div>

    <div class="grid grid-cols-4 gap-3.5 mb-7">
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5"><div class="text-xs text-gray-400 mb-0.5">事例数</div><div class="text-lg font-semibold text-gray-900" id="s-total">0</div></div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5"><div class="text-xs text-gray-400 mb-0.5">表示中</div><div class="text-lg font-semibold text-primary" id="s-show">0</div></div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5"><div class="text-xs text-gray-400 mb-0.5">初級</div><div class="text-lg font-semibold text-success-dark" id="s-beg">0</div></div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5"><div class="text-xs text-gray-400 mb-0.5">上級</div><div class="text-lg font-semibold text-purple-600" id="s-adv">0</div></div>
    </div>

    <div class="bg-white rounded-[10px] border border-base-border p-4 mb-5">
      <div class="flex items-center gap-3 mb-3">
        <input type="text" id="search" placeholder="キーワードで検索..." class="flex-1 px-3 py-2 border border-base-border rounded-lg text-sm focus:outline-none focus:border-primary" />
        <select id="sort" class="px-3 py-2 border border-base-border rounded-lg text-xs bg-white cursor-pointer">
          <option value="id">ID順</option>
          <option value="level">難易度順</option>
        </select>
      </div>
      <div class="flex items-center gap-2 mb-2 flex-wrap">
        <span class="text-[11px] text-gray-400 w-16 shrink-0">カテゴリ:</span>
        <button class="cf active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="all">すべて</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="fukugyou">副業</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="kojin_dev">個人開発</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="hongyou">本業効率化</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="toushi">投資・資産管理</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="kigyou">起業</button>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[11px] text-gray-400 w-16 shrink-0">難易度:</span>
        <button class="lf active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="all">すべて</button>
        <button class="lf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="初級">初級</button>
        <button class="lf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="中級">中級</button>
        <button class="lf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-v="上級">上級</button>
      </div>
    </div>

    <div id="list" class="grid grid-cols-1 gap-3"></div>
    <div id="empty" class="hidden text-center py-16"><p class="text-sm text-gray-400">条件に一致する事例がありません</p></div>
  </main>
</Layout>

<style>
  .cf.active,.lf.active{background-color:var(--color-primary-bg);color:var(--color-primary);border-color:var(--color-primary-border)}
  .cf:not(.active),.lf:not(.active){background-color:white;color:#6b7280;border-color:var(--color-base-border)}
</style>

<script type="application/json" id="cases-data" set:html={allCasesJson}></script>

<script>
const D = JSON.parse(document.getElementById('cases-data').textContent);

const CL = {fukugyou:"副業",kojin_dev:"個人開発",hongyou:"本業効率化",toushi:"投資・資産管理",kigyou:"起業"};
const CC = {fukugyou:"bg-orange-100 text-orange-700",kojin_dev:"bg-blue-100 text-blue-700",hongyou:"bg-green-100 text-green-700",toushi:"bg-purple-100 text-purple-700",kigyou:"bg-pink-100 text-pink-700"};
const LC = {"初級":"bg-green-100 text-green-700","中級":"bg-blue-100 text-blue-700","上級":"bg-purple-100 text-purple-700"};
const LV_ORDER = {"初級":1,"中級":2,"上級":3};

let fC='all',fL='all',q='',srt='id';

function render(){
  let f=D.filter(c=>{
    if(fC!=='all'&&c.cat!==fC)return false;
    if(fL!=='all'&&c.level!==fL)return false;
    if(q){const s=q.toLowerCase();return c.title.toLowerCase().includes(s)||c.summary.toLowerCase().includes(s)||c.situation.toLowerCase().includes(s)||(c.tags||[]).some(t=>t.toLowerCase().includes(s));}
    return true;
  });
  if(srt==='id')f.sort((a,b)=>a.id-b.id);
  else if(srt==='level')f.sort((a,b)=>LV_ORDER[a.level]-LV_ORDER[b.level]);

  document.getElementById('s-total').textContent=D.length;
  document.getElementById('s-show').textContent=f.length;
  document.getElementById('s-beg').textContent=D.filter(c=>c.level==='初級').length;
  document.getElementById('s-adv').textContent=D.filter(c=>c.level==='上級').length;

  const el=document.getElementById('list'),no=document.getElementById('empty');
  if(!f.length){el.innerHTML='';no.classList.remove('hidden');return;}
  no.classList.add('hidden');
  el.innerHTML=f.map(c=>`<a href="/cases/${c.slug}" class="block bg-white rounded-[10px] border border-base-border p-5 hover:border-primary-pale hover:shadow-[0_2px_8px_rgba(83,74,183,0.08)] transition-all no-underline">
    <div class="flex items-start justify-between gap-3 mb-2">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-[10px] px-2 py-0.5 rounded-full ${CC[c.cat]}">${CL[c.cat]}</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full ${LC[c.level]}">${c.level}</span>
        <span class="text-[10px] text-gray-400">#${c.id}</span>
      </div>
      <div class="text-sm font-bold text-success-dark shrink-0">${c.impact}</div>
    </div>
    <h3 class="text-sm font-semibold text-gray-900 mb-2">${c.title}</h3>
    <p class="text-xs text-gray-600 mb-2">${c.summary}</p>
    <div class="flex items-center gap-1 flex-wrap">
      ${(c.tags||[]).map(tag=>`<span class="text-[9px] px-1.5 py-0.5 rounded bg-base-muted text-gray-500">${tag}</span>`).join('')}
    </div>
  </a>`).join('');
}

document.querySelectorAll('.cf').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.cf').forEach(x=>x.classList.remove('active'));b.classList.add('active');fC=b.dataset.v;render();});});
document.querySelectorAll('.lf').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.lf').forEach(x=>x.classList.remove('active'));b.classList.add('active');fL=b.dataset.v;render();});});
document.getElementById('sort').addEventListener('change',e=>{srt=e.target.value;render();});
let st;document.getElementById('search').addEventListener('input',e=>{clearTimeout(st);st=setTimeout(()=>{q=e.target.value.trim();render();},200);});
render();
</script>
