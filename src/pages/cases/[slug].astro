---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import fukugyou from '../../data/cases/fukugyou.json';
import kojin_dev from '../../data/cases/kojin_dev.json';
import hongyou from '../../data/cases/hongyou.json';
import toushi from '../../data/cases/toushi.json';
import kigyou from '../../data/cases/kigyou.json';

const ALL_CASES = [...fukugyou, ...kojin_dev, ...hongyou, ...toushi, ...kigyou];

export function getStaticPaths() {
  return Array.from({length:150},(_,i)=>({params:{slug:`case-${i+1}`}}));
}

const { slug } = Astro.params;
const c: any = ALL_CASES.find((x: any) => x.slug === slug) || ALL_CASES[0];
const prev: any = ALL_CASES.find((x: any) => x.id === c.id - 1);
const next: any = ALL_CASES.find((x: any) => x.id === c.id + 1);

const CL: Record<string,string> = {
  fukugyou: "副業",
  kojin_dev: "個人開発",
  hongyou: "本業効率化",
  toushi: "投資・資産管理",
  kigyou: "起業"
};
const CC: Record<string,string> = {
  fukugyou: "bg-orange-100 text-orange-700",
  kojin_dev: "bg-blue-100 text-blue-700",
  hongyou: "bg-green-100 text-green-700",
  toushi: "bg-purple-100 text-purple-700",
  kigyou: "bg-pink-100 text-pink-700"
};
const LC: Record<string,string> = {
  "初級": "bg-green-100 text-green-700",
  "中級": "bg-blue-100 text-blue-700",
  "上級": "bg-purple-100 text-purple-700"
};
---

<Layout title={`${c.title} — 事例集 — Claude Code Academy`}>
  <Sidebar currentPage="cases" />
  <main class="ml-[260px] p-8 min-h-screen">
    <div class="flex items-center gap-2 text-xs text-gray-400 mb-6">
      <a href="/cases" class="hover:text-primary transition-colors no-underline text-gray-400">事例集</a>
      <span>/</span>
      <span class="text-gray-400">{CL[c.cat]}</span>
      <span>/</span>
      <span class="text-gray-600">#{c.id}</span>
    </div>

    <div class="max-w-3xl">
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <span class={`text-[11px] px-2.5 py-0.5 rounded-full ${CC[c.cat]}`}>{CL[c.cat]}</span>
          <span class={`text-[11px] px-2.5 py-0.5 rounded-full ${LC[c.level]}`}>{c.level}</span>
        </div>
        <h1 class="text-2xl font-semibold text-gray-900 mb-2">{c.title}</h1>
        <div class="text-2xl font-bold text-success-dark">{c.impact}</div>
      </div>

      <section class="mb-8">
        <div class="bg-primary-bg rounded-xl p-5 border border-primary-border">
          <p class="text-sm text-gray-700">{c.summary}</p>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">こんな人に向いている</h2>
        <div class="bg-yellow-50 rounded-xl p-5 border border-yellow-100">
          <p class="text-sm text-gray-700">{c.situation}</p>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">実装ステップ</h2>
        <div class="space-y-5">
          {c.steps.map((step: any) => (
            <div class="bg-white rounded-xl border border-base-border p-5">
              <h3 class="text-sm font-semibold text-primary mb-2">{step.title}</h3>
              <p class="text-sm text-gray-700 mb-3 whitespace-pre-wrap">{step.detail}</p>
              <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
                <div class="text-[10px] text-gray-400 font-medium mb-1">プロンプト例</div>
                <p class="text-xs text-gray-600 font-mono whitespace-pre-wrap">{step.prompt}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">つまずきポイント</h2>
        <div class="space-y-2">
          {c.pitfalls.map((p: string) => (
            <div class="flex items-start gap-2 bg-red-50 rounded-lg p-3 border border-red-100">
              <span class="text-red-400 mt-0.5 shrink-0">⚠</span>
              <p class="text-sm text-gray-700">{p}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">期待できる成果</h2>
        <div class="bg-green-50 rounded-xl p-5 border border-green-100">
          <p class="text-sm text-gray-700">{c.result}</p>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">応用のヒント</h2>
        <div class="space-y-2">
          {c.tips.map((tip: string) => (
            <div class="flex items-start gap-2 bg-white rounded-lg p-3 border border-base-border">
              <span class="text-primary mt-0.5 shrink-0">💡</span>
              <p class="text-sm text-gray-700">{tip}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <div class="flex items-center gap-2 flex-wrap">
          {c.tags.map((tag: string) => (
            <span class="text-[11px] px-2.5 py-1 rounded-full bg-base-muted text-gray-500">{tag}</span>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <div class="bg-white rounded-xl border border-primary-border p-5 text-center">
          <p class="text-sm text-gray-700 mb-3">この事例を参考に学ぶ</p>
          <div class="flex justify-center gap-3">
            {c.cat === 'kojin_dev' && <a href="/track/engineer" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-medium no-underline hover:bg-primary-dark transition-colors">エンジニアコースへ</a>}
            {c.cat !== 'kojin_dev' && <a href="/track/business" class="px-5 py-2.5 bg-success text-white rounded-lg text-sm font-medium no-underline hover:opacity-90 transition-colors">ビジネスコースへ</a>}
            <a href="/tips" class="px-5 py-2.5 bg-transparent text-primary border border-primary-border rounded-lg text-sm no-underline hover:bg-primary-bg transition-colors">Tips集を見る</a>
          </div>
        </div>
      </section>

      <div class="flex items-center justify-between pt-6 border-t border-base-border">
        {prev ? (
          <a href={`/cases/${prev.slug}`} class="px-4 py-2 bg-transparent text-primary border border-primary-border rounded-lg text-sm no-underline hover:bg-primary-bg transition-all">← 前の事例</a>
        ) : <div />}
        <a href="/cases" class="px-4 py-2 text-gray-500 text-sm no-underline hover:text-primary transition-colors">一覧に戻る</a>
        {next ? (
          <a href={`/cases/${next.slug}`} class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium no-underline hover:bg-primary-dark transition-colors">次の事例 →</a>
        ) : <div />}
      </div>
    </div>
  </main>
</Layout>
