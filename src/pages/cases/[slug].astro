export function getStaticPaths() {
  return Array.from({length:80},(_,i)=>({params:{slug:`case-${i+1}`}}));
}

const { slug } = Astro.params;
const c = D.find(x => `case-${x.id}` === slug) || D[0];
const prev = D.find(x => x.id === c.id - 1);
const next = D.find(x => x.id === c.id + 1);
const related = (c.rel || []).map(id => D.find(x => x.id === id)).filter(Boolean);

const CL: Record<string,string> = {"dev":"開発効率化","auto":"業務自動化","data":"データ分析","content":"コンテンツ"};
const CC: Record<string,string> = {"dev":"bg-blue-100 text-blue-700","auto":"bg-green-100 text-green-700","data":"bg-purple-100 text-purple-700","content":"bg-orange-100 text-orange-700"};
const JL: Record<string,string> = {"eng":"エンジニア","biz":"ビジネス職","non":"非エンジニア"};
const JC: Record<string,string> = {"eng":"bg-yellow-50 text-yellow-700","biz":"bg-primary-bg text-primary","non":"bg-pink-50 text-pink-700"};
const LC: Record<string,string> = {"初級":"bg-green-100 text-green-700","中級":"bg-blue-100 text-blue-700","上級":"bg-purple-100 text-purple-700"};
---

<Layout title={`${c.t} — 事例集 — Claude Code Academy`}>
  <Sidebar currentPage="cases" />
  <main class="ml-[260px] p-8 min-h-screen">
    <div class="flex items-center gap-2 text-xs text-gray-400 mb-6">
      <a href="/cases" class="hover:text-primary transition-colors no-underline text-gray-400">事例集</a>
      <span>/</span>
      <span class="text-gray-400">{CL[c.cat]}</span>
      <span>/</span>
      <span class="text-gray-600">#{c.id}</span>
    </div>

    <div class="max-w-3xl">
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <span class={`text-[11px] px-2.5 py-0.5 rounded-full ${CC[c.cat]}`}>{CL[c.cat]}</span>
          <span class={`text-[11px] px-2.5 py-0.5 rounded-full ${JC[c.job]}`}>{JL[c.job]}</span>
          <span class={`text-[11px] px-2.5 py-0.5 rounded-full ${LC[c.lv]}`}>{c.lv}</span>
          <span class="text-[11px] text-gray-400">{c.dt}</span>
          <span class="text-[11px] text-gray-400">· {c.src}</span>
        </div>
        <h1 class="text-2xl font-semibold text-gray-900 mb-2">{c.t}</h1>
        {c.p > 0 && <div class="text-3xl font-bold text-success-dark">-{c.p}% 削減</div>}
      </div>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">背景・課題（Before）</h2>
        <div class="bg-red-50 rounded-xl p-5 border border-red-100">
          <p class="text-sm text-gray-700">{c.b}</p>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">解決方法（How）</h2>
        <div class="bg-white rounded-xl border border-base-border p-5">
          <p class="text-sm text-gray-700">{c.h}</p>
          <div class="flex items-center gap-1 flex-wrap mt-3">
            {c.tags.map((tag: string) => (
              <span class="text-[10px] px-2 py-0.5 rounded bg-base-muted text-gray-500">{tag}</span>
            ))}
          </div>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">成果（After）</h2>
        <div class="bg-green-50 rounded-xl p-5 border border-green-100">
          <p class="text-sm text-gray-700 font-medium">{c.a}</p>
        </div>
      </section>

      {c.app && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-gray-900 mb-3">応用アイデア</h2>
          <div class="bg-primary-bg rounded-xl p-5">
            <p class="text-sm text-gray-700">{c.app}</p>
          </div>
        </section>
      )}

      {related.length > 0 && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-gray-900 mb-3">関連事例</h2>
          <div class="space-y-2">
            {related.map((r: any) => (
              <a href={`/cases/case-${r.id}`} class="flex items-center gap-3 p-3 bg-white rounded-lg border border-base-border hover:border-primary-pale transition-all no-underline">
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-base-muted text-gray-500">#{r.id}</span>
                <span class="text-sm text-gray-900 flex-1">{r.t}</span>
                {r.p > 0 && <span class="text-xs font-bold text-success-dark">-{r.p}%</span>}
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="mb-8">
        <div class="bg-white rounded-xl border border-primary-border p-5 text-center">
          <p class="text-sm text-gray-700 mb-3">この事例を参考に学ぶ</p>
          <div class="flex justify-center gap-3">
            {c.job === 'eng' && <a href="/track/engineer" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-medium no-underline hover:bg-primary-dark transition-colors">エンジニアコースへ</a>}
            {c.job === 'biz' && <a href="/track/business" class="px-5 py-2.5 bg-success text-white rounded-lg text-sm font-medium no-underline hover:opacity-90 transition-colors">ビジネスコースへ</a>}
            {c.job === 'non' && <a href="/track/business" class="px-5 py-2.5 bg-success text-white rounded-lg text-sm font-medium no-underline hover:opacity-90 transition-colors">ビジネスコースへ</a>}
            <a href="/tips" class="px-5 py-2.5 bg-transparent text-primary border border-primary-border rounded-lg text-sm no-underline hover:bg-primary-bg transition-colors">Tips集を見る</a>
          </div>
        </div>
      </section>

      <div class="flex items-center justify-between pt-6 border-t border-base-border">
        {prev ? (
          <a href={`/cases/case-${prev.id}`} class="px-4 py-2 bg-transparent text-primary border border-primary-border rounded-lg text-sm no-underline hover:bg-primary-bg transition-all">← 前の事例</a>
        ) : <div />}
        <a href="/cases" class="px-4 py-2 text-gray-500 text-sm no-underline hover:text-primary transition-colors">一覧に戻る</a>
        {next ? (
          <a href={`/cases/case-${next.id}`} class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium no-underline hover:bg-primary-dark transition-colors">次の事例 →</a>
        ) : <div />}
      </div>
    </div>
  </main>
</Layout>
