export function getStaticPaths() {
  return Array.from({length:150},(_,i)=>({params:{slug:`tip-${i+1}`}}));
}

const { slug } = Astro.params;
const tip = T.find(t => t.slug === slug) || T[0];
const prevTip = T.find(t => t.id === tip.id - 1);
const nextTip = T.find(t => t.id === tip.id + 1);
const relatedTips = (tip.related || []).map(id => T.find(t => t.id === id)).filter(Boolean);

const catLabels: Record<string,string> = {ui:"UI・操作",prompt:"プロンプト",workflow:"ワークフロー",config:"設定",external:"外部連携",trouble:"トラブルシューティング",hidden:"隠れ機能"};
const levelColors: Record<string,string> = {"初級":"bg-green-100 text-green-700","中級":"bg-blue-100 text-blue-700","上級":"bg-purple-100 text-purple-700"};
const impactColors: Record<string,string> = {"高":"bg-red-50 text-red-600","中":"bg-yellow-50 text-yellow-600","低":"bg-gray-50 text-gray-500"};
---

<Layout title={`${tip.title} — Tips — Claude Code Academy`}>
  <Sidebar currentTrack="" currentPage="tips" />

  <main class="ml-[260px] p-8 min-h-screen">
    <!-- パンくずリスト -->
    <div class="flex items-center gap-2 text-xs text-gray-400 mb-6">
      <a href="/tips" class="hover:text-primary transition-colors no-underline text-gray-400">Tips集</a>
      <span>/</span>
      <span class="text-gray-400">{catLabels[tip.cat]}</span>
      <span>/</span>
      <span class="text-gray-600">#{tip.id}</span>
    </div>

    <div class="max-w-3xl">
      <!-- ヘッダー -->
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <span class={`text-[11px] px-2.5 py-0.5 rounded-full ${levelColors[tip.level]}`}>{tip.level}</span>
          <span class={`text-[11px] px-2.5 py-0.5 rounded-full ${impactColors[tip.impact]}`}>効果: {tip.impact}</span>
          <span class="text-[11px] px-2.5 py-0.5 rounded-full bg-base-muted text-gray-500">{catLabels[tip.cat]}</span>
          <span class="text-[11px] px-2.5 py-0.5 rounded-full bg-base-muted text-gray-500">#{tip.id}</span>
        </div>
        <h1 class="text-2xl font-semibold text-gray-900 mb-2">{tip.title}</h1>
        <p class="text-sm text-gray-500">{tip.summary}</p>
      </div>

      <!-- 概要セクション -->
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">どんな場面で使うか</h2>
        <div class="space-y-2">
          {tip.scenes.map((scene: string) => (
            <div class="flex items-start gap-2">
              <span class="text-primary mt-0.5 shrink-0">▸</span>
              <p class="text-sm text-gray-600">{scene}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- 実践セクション -->
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">実践手順</h2>
        <div class="space-y-3">
          {tip.steps.map((step: string, i: number) => (
            <div class="flex items-start gap-3">
              <div class="w-7 h-7 rounded-full bg-primary-bg flex items-center justify-center text-xs font-bold text-primary shrink-0">{i + 1}</div>
              <p class="text-sm text-gray-600 pt-1">{step}</p>
            </div>
          ))}
        </div>
        {tip.code && (
          <div class="mt-4 bg-gray-900 rounded-lg p-4">
            <code is:raw class="text-[11px] text-green-400 font-mono leading-relaxed whitespace-pre-wrap">{tip.code}</code>
          </div>
        )}
      </section>

      <!-- 応用セクション -->
      {tip.advanced && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-gray-900 mb-3">応用テクニック</h2>
          <div class="bg-primary-bg rounded-xl p-5">
            <p class="text-sm text-gray-700">{tip.advanced}</p>
          </div>
        </section>
      )}

      <!-- 関連Tips -->
      {relatedTips.length > 0 && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-gray-900 mb-3">関連Tips</h2>
          <div class="grid grid-cols-1 gap-2">
            {relatedTips.map((rt: any) => (
              <a href={`/tips/tip-${rt.id}`} class="flex items-center gap-3 p-3 bg-white rounded-lg border border-base-border hover:border-primary-pale hover:shadow-sm transition-all no-underline">
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-base-muted text-gray-500">#{rt.id}</span>
                <span class="text-sm text-gray-900">{rt.title}</span>
                <span class={`text-[10px] px-2 py-0.5 rounded-full ${levelColors[rt.level]} ml-auto`}>{rt.level}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- 注意事項 -->
      {tip.caution && (
        <section class="mb-8">
          <div class="bg-yellow-50 rounded-xl p-5 border border-yellow-200">
            <p class="text-sm text-yellow-700 font-medium mb-1">注意事項</p>
            <p class="text-sm text-gray-700">{tip.caution}</p>
          </div>
        </section>
      )}

      <!-- 練習問題 -->
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">練習問題</h2>
        <div class="bg-white rounded-xl border border-primary-border p-5">
          <p class="text-sm text-gray-700 mb-4">{tip.exercise}</p>
          <button id="complete-btn" class="w-full py-3 bg-primary text-white border-none rounded-lg text-sm font-medium cursor-pointer hover:bg-primary-dark transition-colors">
            完了する（+10 XP）
          </button>
          <div id="completed-msg" class="hidden w-full py-3 bg-success-bg text-success-dark rounded-lg text-sm font-medium text-center">
            完了済み
          </div>
        </div>
      </section>

      <!-- ナビゲーション -->
      <div class="flex items-center justify-between pt-6 border-t border-base-border">
        {prevTip ? (
          <a href={`/tips/tip-${prevTip.id}`} class="px-5 py-2.5 bg-transparent text-primary border border-primary-border rounded-lg text-sm no-underline hover:bg-primary-bg transition-all">← #{prevTip.id} {prevTip.title.slice(0, 20)}...</a>
        ) : <div />}
        <a href="/tips" class="px-4 py-2 text-gray-500 text-sm no-underline hover:text-primary transition-colors">一覧に戻る</a>
        {nextTip ? (
          <a href={`/tips/tip-${nextTip.id}`} class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-medium no-underline hover:bg-primary-dark transition-colors">#{nextTip.id} {nextTip.title.slice(0, 20)}... →</a>
        ) : <div />}
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ tipId: tip.id }}>
  const STORAGE_KEY = 'cca-tips-progress';
  const btn = document.getElementById('complete-btn');
  const msg = document.getElementById('completed-msg');

  function loadProgress() {
    try { const raw = localStorage.getItem(STORAGE_KEY); return raw ? JSON.parse(raw) : {}; } catch { return {}; }
  }

  function isCompleted() { return !!loadProgress()[tipId]; }

  function complete() {
    const data = loadProgress();
    data[tipId] = { completed: true, at: new Date().toISOString() };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    // XP加算
    const xpKey = 'cca-progress';
    try {
      const raw = localStorage.getItem(xpKey);
      const p = raw ? JSON.parse(raw) : { xp: 0, level: 1 };
      p.xp = (p.xp || 0) + 10;
      p.level = Math.floor(p.xp / 200) + 1;
      localStorage.setItem(xpKey, JSON.stringify(p));
    } catch {}
  }

  if (isCompleted()) { btn.classList.add('hidden'); msg.classList.remove('hidden'); }
  btn.addEventListener('click', () => { complete(); btn.classList.add('hidden'); msg.classList.remove('hidden'); });
</script>
