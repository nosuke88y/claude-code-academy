---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';

// 全150 Tips詳細データ
const T = [
// id,slug,cat,title,level,impact,summary,scenes,steps,code,advanced,related,caution,exercise
{id:1,slug:"tip-1",cat:"ui",title:"Shift+Tab でPermission mode即切替",level:"初級",impact:"高",
summary:"作業中にワンキーでAsk/Auto Edit/Full Autoを瞬時に切り替える",
scenes:["コード調査中はAskモードで安全に確認しながら作業したい","信頼できる修正作業に入ったらAuto Editで高速化したい","テスト環境で自由に実験する時はFull Autoに"],
steps:["Claude Codeを起動する","Shift+Tab を押すとモード表示が切り替わる","現在のモードがプロンプトバーに表示される","作業フェーズに応じて適切なモードを選択"],
code:"# プロンプトバーの表示が変わる\n[Ask] → [Auto Edit] → [Full Auto] → [Ask]...\n\n# Shift+Tabを押すたびにサイクル",
advanced:"Windowsの一部ターミナルではAlt+Mが代替キー。VS Code Terminalでは/terminal-setupを先に実行すると確実。",
related:[67,110,128],caution:"Full Autoモードは全操作が自動承認される。本番環境では必ずAskモードを使うこと。",
exercise:"Claude Codeを起動して、Shift+Tabを3回押してモードが巡回することを確認してください。各モードでファイル作成を試し、確認プロンプトの違いを体感しましょう。"},

{id:2,slug:"tip-2",cat:"ui",title:"Ctrl+R でコマンド履歴を逆検索",level:"初級",impact:"中",
summary:"過去のプロンプトをインクリメンタル検索して再利用する",
scenes:["昨日使った長いプロンプトを再利用したい","特定のキーワードを含む過去の指示を探したい"],
steps:["Ctrl+R を押す","検索したいキーワードを入力","マッチした過去のプロンプトが表示される","Enterで選択、Ctrl+Rで次の候補に移動"],
code:"# Ctrl+R → 検索キーワード入力\n(reverse-i-search)`test': npm run testを実行して結果を分析して",
advanced:"シェルのCtrl+Rと同じ操作感。検索結果が見つかったらCtrl+Eで編集モードに入り、プロンプトを修正してから送信できる。",
related:[49,54],caution:"",
exercise:"Claude Codeで3つ以上のプロンプトを送信した後、Ctrl+Rで最初のプロンプトを検索して呼び出してください。"},

{id:3,slug:"tip-3",cat:"ui",title:"Ctrl+O でトランスクリプトビューア表示",level:"中級",impact:"高",
summary:"Claude Codeの内部動作（ツール呼び出しの詳細ログ）を確認する",
scenes:["Claude Codeが予期しないファイルを変更した原因を調べたい","サブエージェントの動作プロセスを確認したい","トークン消費がどこで発生しているか知りたい"],
steps:["Ctrl+O を押す","トランスクリプトビューアが表示される","↑↓キーでスクロール","Ctrl+Eで全コンテンツ表示を切り替え","qまたはEscで閉じる"],
code:"# トランスクリプトビューア内のショートカット\nCtrl+E  全コンテンツ表示切替\n[       会話をネイティブスクロールバックに出力\nv       会話をファイルに保存してエディタで開く\nq/Esc   閉じる",
advanced:"vキーでファイルに保存すると$EDITORで開かれる。ログの検索や他メンバーとの共有に便利。",
related:[103,104,27],caution:"",
exercise:"何か指示を出した後にCtrl+Oを押して、Claude Codeがどのツール（Read, Edit, Bash等）をどの順番で使ったか確認してください。"},

{id:4,slug:"tip-4",cat:"ui",title:"バックスラッシュ+Enter で複数行入力",level:"初級",impact:"高",
summary:"全ターミナル対応の改行方法で長いプロンプトを構造化して入力する",
scenes:["複数のステップを含む長い指示を書きたい","コードブロックを含むプロンプトを送りたい","Shift+Enterが効かないターミナルで改行したい"],
steps:["プロンプト入力中に \\ を入力","続けてEnterキーを押す","次の行に移動して入力を続ける","最後の行でそのままEnterを押すと送信"],
code:"この関数を修正して。\\\nステップ1: エラーハンドリング追加\\\nステップ2: テストも書いて\\\nステップ3: ドキュメントも更新",
advanced:"Ctrl+Jでも改行可能（全ターミナル対応）。iTerm2/WezTerm/Ghostty/KittyではShift+Enterがデフォルトで使える。",
related:[102,134],caution:"VS Code Terminalでは/terminal-setupを先に実行するとShift+Enterも使えるようになる。",
exercise:"バックスラッシュ+Enterで3行以上のプロンプトを作成し、番号付きステップで指示を送信してください。"},

{id:5,slug:"tip-5",cat:"ui",title:"Ctrl+V で画像をクリップボードから貼付",level:"中級",impact:"高",
summary:"スクリーンショットやUI画像を直接貼り付けてClaude Codeに分析させる",
scenes:["エラー画面のスクリーンショットを見せて修正を依頼したい","デザインモックのスクショからUIコンポーネントを生成したい","実機のバグ画面を共有して原因調査を依頼したい"],
steps:["ブラウザやアプリでスクリーンショットをクリップボードにコピー","Claude Codeのプロンプトに戻る","Ctrl+V（macOSはCmd+V）で貼り付け","画像が[Image #1]として表示される","「この画像のエラーを修正して」等の指示を送信"],
code:"# 画像貼り付け後のプロンプト例\n> [Image #1]\n> このエラー画面を分析して修正方法を提案して\n\n# 複数画像も可能\n> [Image #1] [Image #2]\n> この2つの画面の違いを説明して",
advanced:"PDF読み込みも対応。@file.pdfでPDFの内容を分析できる。複数画像を同時に貼り付けて比較分析も可能。",
related:[148,150],caution:"WindowsではAlt+Vの場合もある。クリップボードに画像がない場合はテキストが貼り付けられる。",
exercise:"ブラウザのスクリーンショットを撮り、Claude Codeに貼り付けて「この画面の構成要素を説明して」と依頼してください。"},

{id:6,slug:"tip-6",cat:"ui",title:"Ctrl+B でバックグラウンドタスク実行",level:"中級",impact:"中",
summary:"長時間のビルドやテストをバックグラウンドで実行しながら別作業を続ける",
scenes:["npm run buildに数分かかるが待ちたくない","テストスイートの実行中に別の質問をしたい"],
steps:["通常通りタスクを依頼する","Ctrl+B を押してバックグラウンドに送る","プロンプトが再び使えるようになる","Ctrl+Tでバックグラウンドタスクの進捗を確認"],
code:"# バックグラウンドタスクの操作\nCtrl+B  タスクをバックグラウンドに送る\nCtrl+T  タスクリスト表示/非表示\n/tasks  バックグラウンドタスク一覧",
advanced:"/tasksコマンドでもバックグラウンドタスクの一覧を確認できる。完了時にNotificationフックで通知を受け取る設定も可能。",
related:[7,80,61],caution:"バックグラウンドタスクもトークンを消費する。同時に多数のタスクを実行するとコストが増加する。",
exercise:"「npm run buildを実行して」と依頼した直後にCtrl+Bを押し、バックグラウンドで実行させながら別の質問をしてみてください。"},

{id:7,slug:"tip-7",cat:"ui",title:"Ctrl+T でタスクリスト表示/非表示",level:"中級",impact:"中",
summary:"バックグラウンドで実行中のタスク一覧をリアルタイムで確認する",
scenes:["バックグラウンドタスクの進捗を知りたい","完了したタスクの結果を確認したい"],
steps:["Ctrl+T を押す","タスクリストが表示される","各タスクのステータス（実行中/完了/エラー）を確認","再度Ctrl+Tで非表示"],
code:"Ctrl+T  タスクリスト表示/非表示\n/tasks  同等のコマンド",
advanced:"/tasksコマンドでも同等の操作が可能。",related:[6,12],caution:"",
exercise:"Ctrl+Bでタスクをバックグラウンドに送った後、Ctrl+Tで進捗を確認してください。"},

{id:8,slug:"tip-8",cat:"ui",title:"Alt+P でモデルを即切替",level:"中級",impact:"高",
summary:"Opus/Sonnet/Haikuをキー一つで切替えてコストと品質を最適化する",
scenes:["設計検討はOpusで深く考えさせ、定型コード生成はSonnetで高速化したい","簡単な質問にHaikuを使ってトークンを節約したい","モデルの回答品質を比較したい"],
steps:["Alt+P（macOSはOption+P）を押す","モデル選択メニューが表示される","使いたいモデルを選択","選択したモデルで次のプロンプトから適用"],
code:"Alt+P (Windows) / Option+P (macOS)\n\n# または/modelコマンドで指定\n/model sonnet\n/model opus\n/model haiku",
advanced:"/effortコマンドと組み合わせると最適化の幅が広がる。Haiku + effort:lowで最速、Opus + effort:maxで最高品質。",
related:[9,10,28],caution:"モデル変更はそのセッション内でのみ有効。新しいセッションではデフォルトモデルに戻る。",
exercise:"Alt+Pで3つのモデルを切り替え、同じ質問をして回答の違いを比較してください。"},

{id:9,slug:"tip-9",cat:"ui",title:"Alt+T で Extended Thinking を切替",level:"中級",impact:"中",
summary:"複雑な推論が必要な時だけ深い思考モードをONにしてトークン節約する",
scenes:["アルゴリズム設計やアーキテクチャの検討で深い分析が欲しい","バグの根本原因分析で複数の仮説を検討させたい"],
steps:["Alt+T（macOSはOption+T）を押す","Extended Thinkingの有効/無効が切り替わる","複雑な質問の前にON、終わったらOFFに"],
code:"Alt+T (Windows) / Option+T (macOS)",
advanced:"settings.jsonでalwaysThinkingEnabled: trueにすると常時有効。",related:[8,28,140],caution:"Extended Thinkingはトークン消費が増える。日常的なタスクでは不要。",
exercise:"簡単な質問と複雑な設計質問を、Extended ThinkingのON/OFFそれぞれで試し、回答の深さの違いを確認してください。"},

{id:10,slug:"tip-10",cat:"ui",title:"Alt+O で高速モード（Fast Mode）切替",level:"初級",impact:"中",
summary:"同じモデルのまま出力速度だけ向上させる",
scenes:["レスポンス待ちが気になる時","大量のコード生成で速度を優先したい時"],
steps:["Alt+O（macOSはOption+O）を押す","Fast Modeが有効になる","再度押すと通常モードに戻る"],
code:"Alt+O (Windows) / Option+O (macOS)\n# または\n/fast",
advanced:"/fastコマンドでも切替可能。品質は変わらないので、基本的にONにしておいてよい。",related:[8,124],caution:"",
exercise:"/fastコマンドでFast Modeを有効にし、コード生成の速度変化を体感してください。"},

{id:11,slug:"tip-11",cat:"ui",title:"Ctrl+G で外部エディタでプロンプト編集",level:"上級",impact:"低",
summary:"VS Code等でプロンプトを編集してから送信する",
scenes:["100行を超える仕様書をプロンプトとして送りたい","複雑なマークダウン形式の指示を書きたい"],
steps:["Ctrl+G（またはCtrl+X Ctrl+E）を押す","$EDITORで設定されたエディタが開く","プロンプトを編集","保存して閉じると自動的に送信される"],
code:"# $EDITORの設定例\nexport EDITOR='code --wait'  # VS Code\nexport EDITOR='vim'          # Vim",
advanced:"エディタでMarkdown形式で書くと見やすい。シンタックスハイライトも使える。",related:[4,134],caution:"$EDITOR環境変数が設定されていないとエラーになる。",
exercise:"$EDITORを設定し、Ctrl+Gでエディタを開いて複数行のプロンプトを書いて送信してください。"},

{id:12,slug:"tip-12",cat:"ui",title:"Ctrl+X Ctrl+K で全バックグラウンドエージェント終了",level:"上級",impact:"低",
summary:"暴走したサブエージェントを一括停止する緊急停止ボタン",
scenes:["サブエージェントが意図しないファイルを大量に変更し始めた","バックグラウンドタスクがリソースを消費しすぎている"],
steps:["Ctrl+X を押す","続けて Ctrl+K を押す","確認メッセージが表示される","もう一度同じキーを押して確認"],
code:"Ctrl+X Ctrl+K  全バックグラウンドエージェント終了\n（2回押しで確認が入る安全設計）",
advanced:"個別のタスク停止は/tasksから行える。",related:[6,7],caution:"全てのバックグラウンドタスクが停止される。特定のタスクだけ止めたい場合は/tasksを使う。",
exercise:"バックグラウンドタスクを2つ起動し、Ctrl+X Ctrl+Kで一括停止を試してください。"},

{id:13,slug:"tip-13",cat:"ui",title:"/config → Vim Mode を有効化",level:"中級",impact:"中",
summary:"Vimキーバインドでプロンプト入力を効率化する",
scenes:["Vim歴のあるエンジニアがClaude Codeの入力効率を上げたい","hjklナビゲーションに慣れている人"],
steps:["/config を実行","Settings → Editor modeを選択","Vimを選択","EscでNORMALモード、i/aでINSERTモードに"],
code:"# NORMALモードの主要操作\nhjkl   移動\ndd     行削除\nyy/p   コピー/ペースト\nw/b    単語単位移動\n0/$    行頭/行末",
advanced:"Vim modeとCtrl系ショートカット（Ctrl+O等）は独立して動作する。両方の恩恵を受けられる。",related:[14],caution:"Vim未経験者には推奨しない。誤操作の原因になる。",
exercise:"/configでVim modeを有効にし、Escキーでノーマルモード、iキーで挿入モードを行き来してください。"},

{id:14,slug:"tip-14",cat:"ui",title:"Vim modeとCtrlショートカットは独立動作",level:"中級",impact:"低",
summary:"Vim操作とClaude Code固有ショートカットを併用できる",
scenes:["VimモードでもCtrl+Oのトランスクリプトを使いたい"],
steps:["Vim modeを有効にする","EscでNORMALモードに入る","Ctrl+O等のショートカットはそのまま動作する"],
code:"Esc        → Vim NORMALモード\nCtrl+O     → トランスクリプト（Vimに関係なく動作）\nCtrl+R     → 履歴検索（Vimに関係なく動作）",
advanced:"",related:[13],caution:"",exercise:"Vim modeを有効にした状態で、Ctrl+OやCtrl+Rが正常に動作することを確認してください。"},

{id:15,slug:"tip-15",cat:"ui",title:"VS Code拡張でエディタから直接起動",level:"初級",impact:"高",
summary:"VS Code内でClaude Codeをシームレスに実行し、開いているファイルを自動でコンテキストに含める",
scenes:["VS Codeでコーディング中にClaude Codeに質問したい","エディタで開いているファイルをそのままレビューさせたい","IDE内で完結した開発体験がほしい"],
steps:["VS Code拡張機能マーケットプレイスで「Claude Code」を検索","Anthropic公式拡張をインストール","コマンドパレットから「Claude Code: Start Session」を実行","Terminalパネルにセッションが開始される"],
code:"# VS Codeのコマンドパレット\nCtrl+Shift+P → Claude Code: Start Session",
advanced:"claude --ideオプションでCLIからIDE連携状態を確認・管理できる。",related:[16,19],caution:"VS Codeの最新版が推奨。古いバージョンでは一部機能が制限される場合がある。",
exercise:"VS Code拡張をインストールし、エディタからClaude Codeセッションを開始してください。開いているファイルについて質問してみましょう。"},

{id:16,slug:"tip-16",cat:"ui",title:"JetBrains拡張でIntelliJ/WebStorm連携",level:"初級",impact:"高",
summary:"JetBrains IDE内でClaude Codeを実行しデバッガーとも連携する",
scenes:["IntelliJ IDEAでJava/Kotlin開発中にClaude Codeを使いたい","WebStormでフロントエンド開発をしながらAIアシスト"],
steps:["JetBrains Marketplace で「Claude Code」を検索","プラグインをインストール","IDE再起動後、ツールウィンドウにClaude Codeが追加される"],
code:"# JetBrains IDE内で利用可能",
advanced:"デバッガーのブレークポイント情報を活用した分析も可能。",related:[15],caution:"",
exercise:"JetBrainsプラグインをインストールし、IDE内からClaude Codeにコードの説明を依頼してみてください。"},

{id:17,slug:"tip-17",cat:"ui",title:"Desktop版のSide Chats機能",level:"中級",impact:"中",
summary:"メインの作業スレッドに影響を与えず別の質問ができる",
scenes:["実装中に仕様の確認をしたいがメインコンテキストを汚したくない","設計相談しながら実装を並行して進めたい"],
steps:["Desktop版でSide Chat を開く","メインスレッドとは独立した会話が始まる","質問・回答してもメインの作業に影響しない"],
code:"",advanced:"Side Chatの結果をメインスレッドに「インポート」することも可能。",related:[29],caution:"Desktop版（Mac/Windows）のみの機能。CLI版では利用不可。",
exercise:"Desktop版でSide Chatを開き、メインスレッドの作業と並行して別の質問を試してください。"},

{id:18,slug:"tip-18",cat:"ui",title:"Desktop版のLive App Preview",level:"中級",impact:"高",
summary:"devサーバーやHTMLファイルをDesktopアプリ内でプレビュー表示する",
scenes:["フロントエンド開発でブラウザとターミナルを行き来したくない","HTMLレポートの出力結果を即座に確認したい"],
steps:["Desktop版でClaude Codeを起動","devサーバーを起動する指示を出す","Live Previewペインが自動で表示される","コード変更がリアルタイムでプレビューに反映"],
code:"",advanced:"PDFプレビューにも対応。レポート生成→確認のサイクルが高速化。",related:[19],caution:"Desktop版のみ。",
exercise:"「シンプルなHTMLページを作成して」と依頼し、Live Previewで表示されることを確認してください。"},

{id:19,slug:"tip-19",cat:"ui",title:"Desktop版のVisual Diff Review",level:"中級",impact:"高",
summary:"コード変更をインラインコメント付きの差分ビューアで確認する",
scenes:["PRレビューをビジュアルに行いたい","Claude Codeの変更内容を承認前に詳細確認したい"],
steps:["Desktop版でコード変更を行う","Visual Diff Reviewが自動表示される","変更箇所にインラインコメントを追加可能","承認または却下を選択"],
code:"",advanced:"/diffコマンドでもCLI上で差分確認は可能だが、Desktop版はよりリッチなUI。",related:[25],caution:"Desktop版のみ。",
exercise:"Desktop版でファイル変更を行い、Visual Diff Reviewで差分を確認してみてください。"},

{id:20,slug:"tip-20",cat:"prompt",title:"/compact [指示] で焦点を絞って圧縮",level:"初級",impact:"高",
summary:"コンテキストが大きくなった時に焦点を指定して効率的に圧縮する",
scenes:["長時間作業でコンテキストが80%を超えた","話題が変わるため不要な情報を削りたい","特定の作業に集中するため関連情報だけ残したい"],
steps:["/compact を入力","オプションで焦点を指定（例: /compact 認証周りに集中）","Claude Codeが会話を要約・圧縮","圧縮後もCLAUDE.mdの内容は全文保持される"],
code:"/compact\n/compact パフォーマンス改善に集中して\n/compact 認証バグの修正に関連する情報だけ残して",
advanced:"compact後もCLAUDE.mdは全文再注入される。重要情報はCLAUDE.mdに書いておくと安全。自動compactもあるが、手動で焦点指定した方が保持率が高い。",
related:[105,107,27],caution:"compact後は会話の詳細な履歴は失われる。重要な決定事項はCLAUDE.mdに記録しておくこと。",
exercise:"/compact を実行して会話が圧縮されることを確認してください。次に /compact テスト作業に集中 のように焦点を指定して違いを確認しましょう。"},

{id:21,slug:"tip-21",cat:"prompt",title:"/batch で大規模変更を並列処理",level:"上級",impact:"高",
summary:"5〜30個の独立した変更を自動分割してサブエージェントで並列実行する",
scenes:["全APIルートにバリデーションを一括追加したい","全コンポーネントの型定義をanyから具体型に変更したい","全テストファイルにカバレッジ改善を適用したい"],
steps:["/batch に続けて指示を入力","Claude Codeがタスクを自動的に独立した単位に分割","各サブエージェントが並列で実行","完了後に全結果がまとめて報告される"],
code:"/batch 全APIルートにバリデーションを追加して\n/batch src/配下のany型を全て具体的な型に置き換えて",
advanced:"依存関係のあるタスクは自動的に順次実行される。完全に独立したタスクほど並列化の効果が大きい。",
