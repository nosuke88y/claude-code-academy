---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<Layout title="Tips & テクニック集 — Claude Code Academy">
  <Sidebar currentTrack="" currentPage="tips" />

  <main class="ml-[260px] p-8 min-h-screen">
    <div class="mb-7">
      <h1 class="text-[22px] font-semibold text-gray-900">Tips & テクニック集</h1>
      <p class="text-sm text-gray-400 mt-1">Claude Codeの150個のTips · カテゴリ別・難易度別に検索 · 初心者〜上級者まで</p>
    </div>

    <!-- 統計カード -->
    <div class="grid grid-cols-4 gap-3.5 mb-7" id="tips-stats">
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">全Tips</div>
        <div class="text-lg font-semibold text-gray-900" id="stat-total">-</div>
      </div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">表示中</div>
        <div class="text-lg font-semibold text-primary" id="stat-showing">120</div>
      </div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">お気に入り</div>
        <div class="text-lg font-semibold text-yellow-500" id="stat-favs">0</div>
      </div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">効果度「高」</div>
        <div class="text-lg font-semibold text-success-dark" id="stat-high">0</div>
      </div>
    </div>

    <!-- 検索 & フィルター -->
    <div class="bg-white rounded-[10px] border border-base-border p-4 mb-5">
      <div class="flex items-center gap-3 mb-3">
        <input type="text" id="search-input" placeholder="キーワードで検索..." class="flex-1 px-3 py-2 border border-base-border rounded-lg text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
        <button id="fav-filter" class="px-3 py-2 border border-base-border rounded-lg text-sm hover:bg-yellow-50 hover:border-yellow-300 transition-all cursor-pointer bg-white" title="お気に入りのみ表示">
          <span class="mr-1">&#9734;</span>お気に入り
        </button>
      </div>

      <!-- 難易度フィルター -->
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[11px] text-gray-400 w-14 shrink-0">難易度:</span>
        <button class="filter-level active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-level="all">すべて</button>
        <button class="filter-level px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-level="初級">初級</button>
        <button class="filter-level px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-level="中級">中級</button>
        <button class="filter-level px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-level="上級">上級</button>
      </div>

      <!-- 効果度フィルター -->
      <div class="flex items-center gap-2">
        <span class="text-[11px] text-gray-400 w-14 shrink-0">効果度:</span>
        <button class="filter-impact active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-impact="all">すべて</button>
        <button class="filter-impact px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-impact="高">高</button>
        <button class="filter-impact px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-impact="中">中</button>
        <button class="filter-impact px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-impact="低">低</button>
      </div>
    </div>

    <!-- カテゴリタブ -->
    <div class="flex gap-1 mb-5 overflow-x-auto pb-1" id="cat-tabs">
      <button class="cat-tab active whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="all">すべて<span class="ml-1 text-gray-400" id="cnt-all"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="ui">UI・操作<span class="ml-1 text-gray-400" id="cnt-ui"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="prompt">プロンプト<span class="ml-1 text-gray-400" id="cnt-prompt"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="workflow">ワークフロー<span class="ml-1 text-gray-400" id="cnt-workflow"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="config">設定<span class="ml-1 text-gray-400" id="cnt-config"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="external">外部連携<span class="ml-1 text-gray-400" id="cnt-external"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="trouble">トラブル<span class="ml-1 text-gray-400" id="cnt-trouble"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="hidden">隠れ機能<span class="ml-1 text-gray-400" id="cnt-hidden"></span></button>
    </div>

    <!-- Tips カード一覧 -->
    <div id="tips-grid" class="grid grid-cols-1 gap-3">
    </div>

    <!-- 0件メッセージ -->
    <div id="no-results" class="hidden text-center py-16">
      <div class="text-4xl mb-3">🔍</div>
      <p class="text-sm text-gray-500">条件に一致するTipsが見つかりませんでした</p>
      <button id="reset-filters" class="mt-3 px-4 py-2 bg-primary text-white rounded-lg text-sm cursor-pointer hover:bg-primary-dark transition-colors border-none">フィルターをリセット</button>
    </div>
  </main>
</Layout>

<style>
  .cat-tab.active { background-color: var(--color-primary-bg); color: var(--color-primary); border-color: var(--color-primary-border); }
  .cat-tab:not(.active) { background-color: white; color: #6b7280; border-color: var(--color-base-border); }
  .cat-tab:not(.active):hover { background-color: var(--color-primary-bg); }
  .filter-level.active, .filter-impact.active { background-color: var(--color-primary-bg); color: var(--color-primary); border-color: var(--color-primary-border); }
  .filter-level:not(.active), .filter-impact:not(.active) { background-color: white; color: #6b7280; border-color: var(--color-base-border); }
  .filter-level:not(.active):hover, .filter-impact:not(.active):hover { background-color: #f9fafb; }
  .fav-active { background-color: #fef9c3 !important; border-color: #facc15 !important; color: #a16207 !important; }
  .tip-card { transition: all 0.15s ease; }
  .tip-card:hover { border-color: var(--color-primary-pale); box-shadow: 0 2px 8px rgba(83,74,183,0.08); }
</style>

<script>
const TIPS = [
  // === 1. UI・操作系 ===
  {id:1,cat:"ui",title:"Shift+Tab でPermission mode即切替",level:"初級",impact:"高",desc:"Ask → Auto Edit → Full Autoをワンキーで切替。コード調査中はAsk、信頼できる修正作業中はAuto Editに瞬時変更できる。作業フェーズに応じた権限管理の基本。"},
  {id:2,cat:"ui",title:"Ctrl+R でコマンド履歴を逆検索",level:"初級",impact:"中",desc:"過去のプロンプトをインクリメンタル検索して再利用。長い指示を毎回タイプし直す手間がなくなる。シェルのCtrl+Rと同じ操作感。"},
  {id:3,cat:"ui",title:"Ctrl+O でトランスクリプトビューア表示",level:"中級",impact:"高",desc:"Claude Codeが内部で使ったツール（Read, Edit, Bash等）の詳細ログを確認できる。意図しない動作の原因調査や、AIの思考プロセスの理解に不可欠。"},
  {id:4,cat:"ui",title:"バックスラッシュ+Enter で複数行入力",level:"初級",impact:"高",desc:"全ターミナル対応の改行方法。長いプロンプトを構造化して入力可能。Shift+Enterが効かない環境（VS Code Terminal等）でも確実に使える。",code:"この関数を修正して。\\\n1. エラーハンドリング追加\\\n2. テストも書いて"},
  {id:5,cat:"ui",title:"Ctrl+V で画像をクリップボードから貼付",level:"中級",impact:"高",desc:"スクリーンショットやUI画像を直接貼り付けてレビュー依頼できる。エラー画面のキャプチャを貼って「これを修正して」が可能。複数画像にも対応。",code:"Ctrl+V (Windows)\nCmd+V (macOS, iTerm2)"},
  {id:6,cat:"ui",title:"Ctrl+B でバックグラウンドタスク実行",level:"中級",impact:"中",desc:"長時間かかるビルドやテストをバックグラウンドで実行し、その間に別の質問や作業が可能。Ctrl+Tでタスク進捗を確認できる。"},
  {id:7,cat:"ui",title:"Ctrl+T でタスクリスト表示/非表示",level:"中級",impact:"中",desc:"バックグラウンドで実行中のタスク一覧をリアルタイム確認。完了したタスクの結果もここから確認できる。"},
  {id:8,cat:"ui",title:"Alt+P でモデルを即切替",level:"中級",impact:"高",desc:"Opus ↔ Sonnet ↔ Haikuをキー一つで切替。設計・アーキテクチャ検討はOpus、定型的なコード生成はSonnet、簡単な質問はHaikuと使い分けてコスト最適化。",code:"Alt+P (Windows)\nOption+P (macOS)"},
  {id:9,cat:"ui",title:"Alt+T で Extended Thinking を切替",level:"中級",impact:"中",desc:"複雑な推論（アルゴリズム設計、バグの根本原因分析等）が必要な時だけONに。通常タスクはOFFでトークン節約。"},
  {id:10,cat:"ui",title:"Alt+O で高速モード（Fast Mode）切替",level:"初級",impact:"中",desc:"同じOpusモデルのまま出力速度だけ向上。品質は変わらないので、レスポンス待ちが気になる時に有効。/fast コマンドでも切替可能。"},
  {id:11,cat:"ui",title:"Ctrl+G で外部エディタでプロンプト編集",level:"上級",impact:"低",desc:"$EDITOR環境変数で指定したエディタ（VS Code等）でプロンプトを編集してから送信。100行を超える複雑な仕様書を指示する時に便利。"},
  {id:12,cat:"ui",title:"Ctrl+X Ctrl+K で全バックグラウンドエージェント終了",level:"上級",impact:"低",desc:"暴走したサブエージェントを一括停止する緊急停止ボタン。2回押しで確認が入る安全設計。個別停止は/tasksから。"},
  {id:13,cat:"ui",title:"/config → Vim Mode を有効化",level:"中級",impact:"中",desc:"hjkl移動、dd削除、yy/pコピペなどVimキーバインドが使える。Vim歴のあるエンジニアは入力効率が大幅に向上する。"},
  {id:14,cat:"ui",title:"Vim modeとCtrlショートカットは独立動作",level:"中級",impact:"低",desc:"EscでVimのNORMALモードに入るが、Ctrl+O（トランスクリプト）等のショートカットはそのまま併用可能。両方の恩恵を受けられる。"},
  {id:15,cat:"ui",title:"VS Code拡張でエディタから直接起動",level:"初級",impact:"高",desc:"Anthropic公式「Claude Code」拡張をインストールすると、VS Code内でClaude Codeセッションを直接開始可能。開いているファイルが自動でコンテキストに含まれる。"},
  {id:16,cat:"ui",title:"JetBrains拡張でIntelliJ/WebStorm連携",level:"初級",impact:"高",desc:"IntelliJ IDEA、WebStorm、PyCharm等のJetBrains IDE内でClaude Codeを実行可能。デバッガーとの連携でブレークポイント情報を活用した分析もできる。"},
  {id:17,cat:"ui",title:"Desktop版のSide Chats機能",level:"中級",impact:"中",desc:"メインの作業スレッドに影響を与えず、別の質問ができる。「この関数の仕様を教えて」と聞きながら、メインスレッドでは実装を進められる。"},
  {id:18,cat:"ui",title:"Desktop版のLive App Preview",level:"中級",impact:"高",desc:"devサーバーの出力やHTMLファイル、PDFをDesktopアプリ内でプレビュー表示。ブラウザとターミナルを行き来する手間が省ける。"},
  {id:19,cat:"ui",title:"Desktop版のVisual Diff Review",level:"中級",impact:"高",desc:"コード変更をインラインコメント付きの差分ビューアで確認。GitHub PRのようなUIでレビューでき、変更の承認・却下が視覚的に行える。"},

  // === 2. プロンプト・指示系 ===
  {id:20,cat:"prompt",title:"/compact [指示] で焦点を絞って圧縮",level:"初級",impact:"高",desc:"コンテキストが大きくなった時に会話を圧縮。「/compact パフォーマンス改善に集中して」のように焦点を指定すると、関連情報を優先保持してくれる。",code:"/compact パフォーマンス改善に集中して"},
  {id:21,cat:"prompt",title:"/batch で大規模変更を並列処理",level:"上級",impact:"高",desc:"5〜30個の独立した変更を自動分割してサブエージェントで並列実行。全APIルートへのバリデーション追加や、全コンポーネントの型定義統一など、大規模リファクタリングの切り札。",code:"/batch 全APIルートにバリデーション追加"},
  {id:22,cat:"prompt",title:"/review でPRレビューを自動実行",level:"初級",impact:"高",desc:"現在のdiffまたは指定PRを自動レビュー。セキュリティ・パフォーマンス・可読性・テスタビリティの観点で分析し、具体的な改善提案を出してくれる。",code:"/review\n/review 42"},
  {id:23,cat:"prompt",title:"/security-review でセキュリティ監査",level:"中級",impact:"高",desc:"保留中の変更をOWASP Top 10の観点で自動セキュリティレビュー。SQLインジェクション、XSS、認証バイパスなどの脆弱性を検出。本番デプロイ前に必ず実行。",code:"/security-review"},
  {id:24,cat:"prompt",title:"/init でCLAUDE.mdを自動生成",level:"初級",impact:"高",desc:"プロジェクトの構造・技術スタック・依存関係を分析して最適なCLAUDE.mdを自動作成。新規プロジェクトの初期設定を一瞬で完了できる。",code:"/init"},
  {id:25,cat:"prompt",title:"/diff でインタラクティブdiffビューア",level:"中級",impact:"中",desc:"Claude Codeが行った変更内容をインタラクティブに確認できる差分ビューア。コミット前の最終チェックに最適。変更の取り消しもここから可能。"},
  {id:26,cat:"prompt",title:"/cost でトークン使用量を確認",level:"初級",impact:"中",desc:"セッションのトークン消費量・APIコスト・レート制限状況をリアルタイムで把握。予算管理やコスト最適化の判断材料に。",code:"/cost"},
  {id:27,cat:"prompt",title:"/context でコンテキスト使用状況を可視化",level:"中級",impact:"中",desc:"何がコンテキストウィンドウを占有しているか視覚的に確認。不要な情報がコンテキストを圧迫していないかの診断に使う。",code:"/context"},
  {id:28,cat:"prompt",title:"/effort [level] で推論の深さを調整",level:"中級",impact:"中",desc:"low/medium/high/xhigh/maxの5段階。ファイル名変更のような簡単なタスクはlowで高速化、アーキテクチャ設計はmaxで深い推論を引き出す。",code:"/effort low\n/effort max"},
  {id:29,cat:"prompt",title:"/branch で会話をブランチ分岐",level:"上級",impact:"中",desc:"現在の時点から会話を分岐させ、別のアプローチを試して比較できる。「React版とVue版、どちらがいいか」をA/Bテスト的に検証可能。",code:"/branch alternative-approach"},
  {id:30,cat:"prompt",title:"/export で会話をテキスト出力",level:"初級",impact:"低",desc:"会話全体をテキストファイルとしてエクスポート。チームへのナレッジ共有、ドキュメント化、後から読み返す時に便利。",code:"/export session-log.txt"},
  {id:31,cat:"prompt",title:"/insights でセッション使用分析",level:"中級",impact:"低",desc:"過去のセッション傾向（使用頻度、コスト、よく使うコマンド等）をレポート化。自分の使い方の改善ポイントを発見できる。"},
  {id:32,cat:"prompt",title:"/team-onboarding でチーム用ガイド生成",level:"中級",impact:"中",desc:"プロジェクトの構造を分析し、新メンバー向けのオンボーディングガイドを自動生成。CLAUDE.mdの設定方法やワークフローの説明を含む。"},
  {id:33,cat:"prompt",title:"/simplify でコード品質を自動改善",level:"中級",impact:"中",desc:"変更されたファイルを自動レビューし、冗長なコードの簡略化・命名改善・構造の最適化を提案・実行してくれる。"},
  {id:34,cat:"prompt",title:"@ファイルパス でファイルを明示参照",level:"初級",impact:"高",desc:"@src/api/auth.ts のように指定すると、そのファイルの内容をコンテキストに明示的に含められる。タブ補完が効くので素早く入力可能。",code:"@src/api/auth.ts このファイルをレビューして"},
  {id:35,cat:"prompt",title:"@フォルダ/ でディレクトリ全体を参照",level:"初級",impact:"高",desc:"@src/components/ で配下の全ファイルをコンテキストに投入。モジュール全体の構造を理解した上での変更指示に最適。",code:"@src/components/ 型定義を統一して"},
  {id:36,cat:"prompt",title:"@URL でWebページを参照",level:"中級",impact:"中",desc:"外部のAPIドキュメントやライブラリのREADMEを直接参照して作業に反映。「@https://docs.example.com この仕様に合わせて実装して」のように使う。"},
  {id:37,cat:"prompt",title:"! でBashコマンドを直接実行",level:"初級",impact:"中",desc:"プロンプト先頭に「!」をつけるとClaude Codeを経由せず直接シェルコマンドを実行。git statusやnpm testの確認に便利。結果は会話コンテキストに含まれる。",code:"!git status\n!npm run test"},
  {id:38,cat:"prompt",title:"「テストも書いて」の一文を追加",level:"初級",impact:"高",desc:"修正指示の末尾に「テストも書いて」を加えるだけでTDD的ワークフローに。テストが仕様書として機能し、修正の正しさを自動検証できる。"},
  {id:39,cat:"prompt",title:"「最小限の変更で」と明示する",level:"初級",impact:"高",desc:"スコープクリープ（関連箇所まで不必要に変更すること）を防ぐ魔法の一文。バグ修正やhotfixでは特に重要。変更行数を最小化し、副作用リスクを下げる。"},
  {id:40,cat:"prompt",title:"番号付きステップで段階的に指示",level:"初級",impact:"高",desc:"「1.分析 2.修正 3.テスト 4.レビュー」のように段階を明示するとClaude Codeの精度が向上。各ステップの完了を確認しながら進められる。"},
  {id:41,cat:"prompt",title:"「〜の観点で」とレビュー観点を限定",level:"中級",impact:"高",desc:"「パフォーマンスの観点でレビューして」のように焦点を絞ると、その領域に特化した深い分析が得られる。観点を3つ以内に絞るのがコツ。"},
  {id:42,cat:"prompt",title:"ネガティブ制約を明示する",level:"中級",impact:"中",desc:"「既存のテストを壊さないで」「新しい依存を追加しないで」「このファイルは変更しないで」等の禁止事項を伝えると、意図しない変更を防げる。"},
  {id:43,cat:"prompt",title:"CLAUDE.mdに @ファイル名 でインポート",level:"中級",impact:"高",desc:"CLAUDE.md内で@README.md @package.json等を参照すると、それらのファイル内容が常に最新の状態で読み込まれる。手動での情報更新が不要に。",code:"# CLAUDE.md内\n@README.md\n@docs/api-spec.md"},
  {id:44,cat:"prompt",title:"サブディレクトリにCLAUDE.mdを配置",level:"中級",impact:"中",desc:"src/api/CLAUDE.md のようにモジュール別の指示を配置可能。そのディレクトリのファイルをClaude Codeが読む時に自動適用される。チーム別のルール管理に有効。"},
  {id:45,cat:"prompt",title:"CLAUDE.local.md で個人設定を分離",level:"中級",impact:"中",desc:".gitignoreに入れる個人設定用ファイル。「返答は日本語で」「コメントは英語で」等、チーム共有のCLAUDE.mdと個人の好みを分離できる。"},
  {id:46,cat:"prompt",title:"CLAUDE.mdの4段階優先順位を理解する",level:"上級",impact:"中",desc:"管理者（組織全体） > プロジェクト（.claude/CLAUDE.md） > ユーザー（~/.claude/CLAUDE.md） > ローカル（CLAUDE.local.md）の順で適用。上位の設定は下位で上書きできない。"},
  {id:47,cat:"prompt",title:"開発コマンド一覧をCLAUDE.mdに記載",level:"初級",impact:"高",desc:"npm run dev, npm run test, npm run lint 等の開発コマンドを書いておくと、Claude Codeが正しいコマンドを自動で使ってくれる。プロジェクト固有のコマンドも含める。"},
  {id:48,cat:"prompt",title:"/debug でデバッグログを有効化",level:"中級",impact:"中",desc:"問題の診断にデバッグログを有効化するスキル。エラーの再現手順を自動で記録し、原因特定を高速化。",code:"/debug api connection issue"},
  {id:49,cat:"prompt",title:"/copy [N] で応答をクリップボードコピー",level:"初級",impact:"中",desc:"直前のClaude応答をクリップボードにコピー。Nを指定すると過去N番目の応答をコピー。Slack共有やドキュメント作成に便利。",code:"/copy\n/copy 3"},

  // === 3. ワークフロー系 ===
  {id:50,cat:"workflow",title:"claude -w でworktree隔離セッション",level:"上級",impact:"高",desc:"自動でgit worktreeを作成し、メインブランチに影響なく独立した作業ディレクトリで開発。複数機能の並列開発や安全な実験に最適。",code:"claude -w feature-auth"},
  {id:51,cat:"workflow",title:"--tmux でtmuxペイン付きworktree",level:"上級",impact:"中",desc:"worktreeと同時にtmuxセッションを自動作成。エディタ・ターミナル・プレビューの3ペイン構成で効率的に作業できる。",code:"claude -w feature --tmux"},
  {id:52,cat:"workflow",title:".worktreeinclude で.envを自動コピー",level:"上級",impact:"高",desc:"プロジェクトルートに.worktreeincludeを置くと、gitignoreされた.envファイル等をworktreeに自動コピー。環境変数が正しく引き継がれる。",code:"# .worktreeinclude\n.env\n.env.local\nconfig/local.json"},
  {id:53,cat:"workflow",title:"symlinkDirectories でnode_modules共有",level:"上級",impact:"中",desc:"settings.jsonでnode_modulesをシンボリックリンクに設定すると、worktreeごとにnpm installが不要。ディスク容量とセットアップ時間を大幅節約。"},
  {id:54,cat:"workflow",title:"claude -c で最新セッションを即再開",level:"初級",impact:"高",desc:"前回の会話をそのまま続行する最速の方法。朝イチの作業再開や、一時中断後の復帰に最適。コンテキストが完全に復元される。",code:"claude -c"},
  {id:55,cat:"workflow",title:"--resume で名前付きセッション復帰",level:"中級",impact:"高",desc:"/renameでセッションに名前をつけておくと、--resume \"名前\"で簡単に復帰可能。複数プロジェクトを並行する場合の管理に便利。",code:"claude --resume auth-refactor"},
  {id:56,cat:"workflow",title:"claude -n でセッション名を指定して開始",level:"中級",impact:"中",desc:"最初から名前をつけてセッションを開始。後から/resumeで探しやすくなる。プロジェクト名や機能名をつけるのがおすすめ。",code:'claude -n "payment-integration"'},
  {id:57,cat:"workflow",title:"/color でセッションの色を変更",level:"初級",impact:"低",desc:"プロンプトバーの色を変更して視覚的にセッションを区別。複数ターミナルで別プロジェクトを作業する際に混同を防ぐ。",code:"/color blue"},
  {id:58,cat:"workflow",title:"「並列で実行して」と明示的に指示",level:"中級",impact:"高",desc:"サブエージェントによる並列処理を明示的にトリガー。「以下の3つを並列で調査して」のように使うと、調査時間が1/3に短縮される。"},
  {id:59,cat:"workflow",title:"「調査→実装」の2フェーズで進める",level:"中級",impact:"高",desc:"Phase1で並列サブエージェントによる調査、Phase2で結果に基づき順次実装する戦略。品質を維持しながら速度を最大化するベストプラクティス。"},
  {id:60,cat:"workflow",title:"ディレクトリ単位でタスクを分割",level:"中級",impact:"高",desc:"「src/api/はバリデーション追加、src/components/は型定義統一、tests/はカバレッジ向上」のように分割するとサブエージェントが並列処理しやすい。"},
  {id:61,cat:"workflow",title:"/loop で定期実行タスクを設定",level:"上級",impact:"中",desc:"指定間隔でプロンプトを定期実行。ビルド監視、デプロイ状況チェック、CI結果の確認等を自動化できる。",code:"/loop 5m ビルドが通るか確認して"},
  {id:62,cat:"workflow",title:"claude --remote でクラウドセッション",level:"上級",impact:"高",desc:"AnthropicのクラウドVM上で実行。ローカルマシンに負荷をかけず、長時間の大規模タスクを処理できる。外出先からモバイルで監視も可能。",code:'claude --remote "認証バグを修正して"'},
  {id:63,cat:"workflow",title:"/teleport でクラウド→ローカルにハンドオフ",level:"上級",impact:"中",desc:"Web版で始めた作業をローカルCLIに引き継ぎ可能。クラウドで計画を立て、ローカルで実装するワークフローに。"},
  {id:64,cat:"workflow",title:"/autofix-pr でPR自動修正（Web版）",level:"上級",impact:"高",desc:"PRを常時監視し、CI失敗やレビューコメントに自動で対応。修正→再push→CI再実行までを自動化。チームの開発速度を大幅向上。",code:"/autofix-pr"},
  {id:65,cat:"workflow",title:"/ultraplan でクラウド計画立案（Web版）",level:"上級",impact:"中",desc:"複雑な実装計画をクラウドの計算リソースで草案作成。多角的な検証を経た高品質な計画が得られる。"},
  {id:66,cat:"workflow",title:"/ultrareview で多エージェントPRレビュー（Web版）",level:"上級",impact:"高",desc:"クラウドで複数エージェントがセキュリティ・パフォーマンス・設計・テストの各観点から並列レビュー。通常の/reviewより格段に深い分析。"},

  // === 4. 設定・カスタマイズ系 ===
  {id:67,cat:"config",title:"plan モードで計画だけ立てさせる",level:"中級",impact:"高",desc:"ファイル変更を一切行わない読み取り専用モード。設計レビューや影響範囲の調査に最適。計画を確認してから実行モードに切り替える安全パターン。",code:"claude --permission-mode plan"},
  {id:68,cat:"config",title:"allow/deny でツール単位の細かい制御",level:"中級",impact:"高",desc:"パターンマッチでツール使用を許可/禁止。「npm run *は許可するがgit pushは要確認」のような細かい制御が可能。チームのセキュリティポリシーに合わせて設定。",code:'"allow": ["Bash(npm run *)"]'},
  {id:69,cat:"config",title:"deny で危険なコマンドをブロック",level:"中級",impact:"高",desc:"curlによる外部通信、.envファイルの読み取り、rm -rfなど危険なコマンドを事前にブロック。うっかりミスによるデータ漏洩や破壊を防止。",code:'"deny": ["Bash(curl *)", "Read(./.env)"]'},
  {id:70,cat:"config",title:"auto モードでバックグラウンド安全チェック",level:"上級",impact:"中",desc:"ツール使用を自動承認しつつ、裏でセキュリティ分類器が危険な操作を検出・ブロック。利便性と安全性を両立する上級者向けモード。"},
  {id:71,cat:"config",title:".claude/skills/ でスキルを作成（推奨）",level:"中級",impact:"高",desc:"SKILL.mdのfrontmatterでツール制限・モデル指定・説明を定義できる高機能なカスタムコマンド。.claude/commands/より推奨。Gitにコミットしてチーム共有可能。"},
  {id:72,cat:"config",title:"$ARGUMENTS で引数を受け取る",level:"中級",impact:"高",desc:"スキル内で$ARGUMENTSを使うと、コマンド実行時の引数を受け取れる。汎用的なレビュー・生成・修正コマンドの作成に不可欠。",code:"/project:fix-issue 123\n→ $ARGUMENTS = \"123\""},
  {id:73,cat:"config",title:"$0, $1 で複数引数を分解",level:"上級",impact:"中",desc:"複数引数を個別に受け取れる。「/project:migrate Button React Vue」で$0=Button, $1=React, $2=Vue。マイグレーションツールの作成に便利。",code:"/project:migrate Button React Vue"},
  {id:74,cat:"config",title:"allowed-tools でスキル内のツール制限",level:"上級",impact:"中",desc:"SKILL.mdのfrontmatterで使用可能なツールを制限。レビュー用スキルはRead/Grepのみ許可する等、最小権限の原則を適用できる。"},
  {id:75,cat:"config",title:"ユーザースキル vs プロジェクトスキル",level:"中級",impact:"中",desc:"~/.claude/skills/は全プロジェクト共通の個人スキル、.claude/skills/はGit管理してチーム共有するプロジェクトスキル。使い分けて管理する。"},
  {id:76,cat:"config",title:"PreToolUse フックで危険操作をブロック",level:"中級",impact:"高",desc:"ツール実行前に発火するフック。本番DB接続文字列を含むコマンドのブロック、特定ディレクトリへの書き込み禁止等の安全ガードを実装できる。"},
  {id:77,cat:"config",title:"PostToolUse フックで自動lint実行",level:"中級",impact:"高",desc:"ファイル変更後に自動でESLint/Prettier修正を実行。Claude Codeの出力が常にプロジェクトのコーディング規約に準拠する。",code:'matcher: "Edit|Write"'},
  {id:78,cat:"config",title:"UserPromptSubmit フックでプロンプト検証",level:"上級",impact:"中",desc:"ユーザーがプロンプトを送信した時に発火。入力バリデーション、追加コンテキストの自動注入、プロンプトのログ記録等に活用。"},
  {id:79,cat:"config",title:"SessionStart フックで環境初期化",level:"上級",impact:"中",desc:"セッション開始時に1回だけ発火。環境変数のチェック、DBマイグレーションの確認、開発サーバーの起動等をセッション開始時に自動実行。"},
  {id:80,cat:"config",title:"Notification フックでデスクトップ通知",level:"中級",impact:"中",desc:"Claude Codeがユーザーへの通知を送る時に発火。長時間タスクの完了をOS通知で知らせる。バックグラウンド作業中に見逃さない。"},
  {id:81,cat:"config",title:"PermissionRequest フックで権限オーバーライド",level:"上級",impact:"中",desc:"権限確認が発生した時にプログラマブルに判定できる。CI環境での自動承認や、特定条件下での自動拒否等に活用。"},
  {id:82,cat:"config",title:"matcher で正規表現パターンを使用",level:"上級",impact:"中",desc:"フックのmatcherで正規表現が使える。「mcp__memory__.*」でMCPのmemoryサーバーの全ツールにマッチ等、柔軟なパターン定義が可能。"},
  {id:83,cat:"config",title:"終了コード2でHookからブロック",level:"上級",impact:"高",desc:"Hook内でexit 2を返すとツール実行を完全ブロック。exit 0は成功続行、それ以外は警告表示のみ。安全ガードの実装には必ずexit 2を使う。"},
  {id:84,cat:"config",title:"${CLAUDE_SESSION_ID} でログ管理",level:"上級",impact:"低",desc:"スキルやフック内でセッションIDを環境変数として参照可能。デバッグログの紐付けやセッション別の分析に活用。"},

  // === 5. 外部ツール連携系 ===
  {id:85,cat:"external",title:"/mcp で接続中MCPサーバーを管理",level:"中級",impact:"中",desc:"現在接続されているMCPサーバーの一覧確認、サーバーの追加・削除を対話的に実行。接続エラーの診断もここから。",code:"/mcp"},
  {id:86,cat:"external",title:".mcp.json でプロジェクト固有MCP設定",level:"中級",impact:"高",desc:"プロジェクトルートに配置してチームで共有できるMCP設定ファイル。git管理することで、チームメンバー全員が同じMCP環境で作業可能。"},
  {id:87,cat:"external",title:"--mcp-config でMCP設定ファイルを指定",level:"上級",impact:"中",desc:"起動時にMCP設定ファイルを明示的に指定。開発環境と本番環境で異なるMCP構成を切り替えられる。",code:"claude --mcp-config ./mcp.json"},
  {id:88,cat:"external",title:"公式MCPサーバー4種を活用",level:"中級",impact:"高",desc:"Anthropic公式のfilesystem、GitHub、PostgreSQL、Puppeteerの4種。品質・安全性が保証されており、これだけでDB操作・GitHub連携・ブラウザ操作をカバー。"},
  {id:89,cat:"external",title:"複数MCPの組み合わせワークフロー",level:"上級",impact:"高",desc:"GitHub MCP + PostgreSQL MCP + Slack MCPを同時接続し、「Issueを読む→DBを確認→コード修正→PR作成→Slack通知」の全自動化が可能。"},
  {id:90,cat:"external",title:"管理者MCP設定で組織的に制御",level:"上級",impact:"中",desc:"managed-mcp.jsonで許可/禁止サーバーを組織レベルで一括管理。セキュリティポリシーに準拠したMCP環境を全メンバーに強制できる。"},
  {id:91,cat:"external",title:"claude -p で非対話モードCI実行",level:"中級",impact:"高",desc:"GitHub Actions等のCIパイプラインから直接呼び出し可能。-p \"query\"で結果を取得し、スクリプトで後処理。CI/CDの知性化に不可欠。",code:'claude -p "このコードを分析して"'},
  {id:92,cat:"external",title:"--output-format json で構造化出力",level:"中級",impact:"高",desc:"CI/CDスクリプトで結果をパースしやすいJSON形式で出力。jqと組み合わせてパイプライン内でClaude Codeの結果を自動処理できる。",code:"claude -p --output-format json"},
  {id:93,cat:"external",title:"--max-turns N でターン数制限",level:"中級",impact:"高",desc:"CIでの無限ループや予想外の長時間実行を防止。--max-turns 5のように上限を設定し、安全にCI環境で利用できる。",code:"claude -p --max-turns 5"},
  {id:94,cat:"external",title:"--max-budget-usd N でコスト上限設定",level:"中級",impact:"高",desc:"1回の実行あたりのコスト上限を設定。CI環境でのコスト暴走を防止。チーム全体の予算管理に必須。",code:"claude -p --max-budget-usd 5.00"},
  {id:95,cat:"external",title:"--no-session-persistence でセッション非保存",level:"中級",impact:"中",desc:"CI環境でセッションデータの蓄積を防止。一時的な分析タスクで不要なデータを残さない。ディスク容量の節約にも。"},
  {id:96,cat:"external",title:"パイプでファイル内容を直接投入",level:"中級",impact:"高",desc:"CIで生成されたログ、テスト結果、ビルドエラーをパイプ経由でClaude Codeに投入し、自動分析させる。",code:'cat error.log | claude -p "エラー原因を分析"'},
  {id:97,cat:"external",title:"--json-schema で出力スキーマを強制",level:"上級",impact:"高",desc:"指定したJSONスキーマに準拠した出力を確実に取得。CIパイプラインの自動化で、期待する形式の出力を保証できる。"},
  {id:98,cat:"external",title:"CLAUDE_CODE_USE_BEDROCK でAWS経由",level:"上級",impact:"中",desc:"企業のAWSアカウント経由でClaude API利用。データがAnthropicに送信されないため、企業のデータ管理ポリシーに準拠できる。"},
  {id:99,cat:"external",title:"CLAUDE_CODE_USE_VERTEX でGCP経由",level:"上級",impact:"中",desc:"Google Cloud Vertex AI経由でClaude API利用。GCPベースの企業インフラとの統合が容易。IAMによるアクセス制御も可能。"},
  {id:100,cat:"external",title:"settings.jsonのenvキーで環境変数管理",level:"中級",impact:"中",desc:"プロジェクト別にMCPサーバーの認証情報等を環境変数として管理。コードに直接書かない安全な運用。",code:'"env": { "API_KEY": "value" }'},

  // === 6. トラブルシューティング系 ===
  {id:101,cat:"trouble",title:"/doctor で環境を自動診断・修正",level:"初級",impact:"高",desc:"インストール状態、設定ファイル、MCP接続、認証情報等の問題を自動診断して修正提案。困ったらまずこれを実行するのが鉄則。",code:"/doctor"},
  {id:102,cat:"trouble",title:"/terminal-setup でShift+Enterを修正",level:"初級",impact:"高",desc:"VS Code Terminal、Alacritty、Warp等でShift+Enterによる改行入力を有効化。キーバインド設定を自動で修正してくれる。",code:"/terminal-setup"},
  {id:103,cat:"trouble",title:"--debug でデバッグモード有効化",level:"上級",impact:"高",desc:"API通信、Hook実行、MCP接続等の詳細ログを出力。原因不明のエラーや予期しない動作の調査に必須のツール。",code:'claude --debug "api,hooks"'},
  {id:104,cat:"trouble",title:"--debug-file でログをファイル出力",level:"上級",impact:"中",desc:"デバッグログを画面に表示せずファイルに保存。作業を妨げずにログを蓄積し、後から詳細分析が可能。",code:"claude --debug-file /tmp/debug.log"},
  {id:105,cat:"trouble",title:"コンテキスト80%超えたら /compact",level:"初級",impact:"高",desc:"自動compactもあるが、手動で焦点を指定した方が重要情報の保持率が高い。「/compact 認証周りの作業に集中」のように使うのがベスト。"},
  {id:106,cat:"trouble",title:"/clear で完全リセット（復帰可能）",level:"初級",impact:"高",desc:"会話をリセットして新規セッションに。/resumeで元のセッションに戻れるので安心して使える。話題が大きく変わる時の切り替えに。"},
  {id:107,cat:"trouble",title:"CLAUDE.mdはcompact後も保持される",level:"中級",impact:"高",desc:"compact後もCLAUDE.mdの内容は全文再注入される。プロジェクトのルール・構造・コマンド等の重要情報はCLAUDE.mdに書くべき理由。"},
  {id:108,cat:"trouble",title:"サブディレクトリCLAUDE.mdの再読み込み",level:"上級",impact:"中",desc:"compact後にサブディレクトリのCLAUDE.mdは失われるが、そのディレクトリのファイルを次に読む時に自動で再適用される。明示的な再読み込みは不要。"},
  {id:109,cat:"trouble",title:"「変更前にgit statusを確認して」と指示",level:"初級",impact:"高",desc:"作業前にgit statusを確認させる習慣をつけると、意図しない変更や未コミットの変更の上書きを防げる。「変更後もgit diffで確認して」を追加するとさらに安全。"},
  {id:110,cat:"trouble",title:"plan モードで確認してから実行",level:"中級",impact:"高",desc:"まずplanモードで計画を見せてもらい、内容に問題がなければ承認して実行モードに切り替えるパターン。大規模変更の安全ネット。"},
  {id:111,cat:"trouble",title:".claude/settings.json をgitにコミット",level:"中級",impact:"高",desc:"チーム全員が同じPermission設定・Hook設定で作業。新メンバーのセットアップ自動化と、設定ミスによるセキュリティ事故の防止に。"},
  {id:112,cat:"trouble",title:"--system-prompt で行動制約を追加",level:"上級",impact:"中",desc:"システムプロンプトで動作制約を強制。テストファイルの変更禁止、特定ライブラリの使用強制等、CLAUDE.mdよりも強い制約を適用。",code:'claude --system-prompt "Never modify test files"'},
  {id:113,cat:"trouble",title:"--append-system-prompt-file でルール適用",level:"上級",impact:"中",desc:"外部ファイルからシステムプロンプトを追加。チームのコーディングスタイルガイドをファイル管理して全メンバーに適用。",code:"claude --append-system-prompt-file ./style-rules.txt"},

  // === 7. 隠れた便利機能 ===
  {id:114,cat:"hidden",title:"--bare で最小限モード起動",level:"上級",impact:"中",desc:"スキル・MCP・CLAUDE.md等を全スキップして最速で起動。「このエラーメッセージの意味は？」のようなシンプルな質問に最適。",code:'claude --bare -p "質問"'},
  {id:115,cat:"hidden",title:"--add-dir で追加ディレクトリをコンテキストに",level:"中級",impact:"高",desc:"monorepoで別パッケージのコードをコンテキストに含める。共有ライブラリの変更が他パッケージに与える影響を分析する時に必須。",code:"claude --add-dir ../libs ../apps"},
  {id:116,cat:"hidden",title:"/copy [N] で過去の応答をコピー",level:"初級",impact:"中",desc:"直前（またはN番目）のClaude応答をクリップボードにコピー。Slackやドキュメントへの貼り付けに便利。"},
  {id:117,cat:"hidden",title:"--fork-session でセッションを分岐",level:"上級",impact:"中",desc:"現在のコンテキストをそのまま保持して新セッションIDで開始。同じ状態から異なるアプローチを試すA/Bテストに。"},
  {id:118,cat:"hidden",title:"DISABLE_GIT_INSTRUCTIONS で自動指示無効化",level:"上級",impact:"低",desc:"Claude Codeが自動的に追加するGit関連の指示を無効化。特殊なGitワークフローで標準指示が干渉する場合に。"},
  {id:119,cat:"hidden",title:"Dispatch from Phone（Desktop版）",level:"中級",impact:"中",desc:"iOS/AndroidのClaudeアプリからDesktopのClaude Codeにタスクを送信可能。外出先からリファクタリングやテスト実行を開始できる。"},
  {id:120,cat:"hidden",title:"--remote-control でWeb版から監視・操作",level:"上級",impact:"中",desc:"ローカルCLIセッションをWeb版ブラウザから監視・操作可能に。ペアプログラミングやリモートサポートに最適。",code:'claude --remote-control "My Project"'},
  {id:121,cat:"hidden",title:"/plugin でプラグイン管理",level:"上級",impact:"低",desc:"サードパーティプラグインのインストール・アンインストール・管理。Claude Codeのエコシステムは急速に拡大中。"},
  {id:122,cat:"hidden",title:"sparsePaths でworktreeの部分チェックアウト",level:"上級",impact:"中",desc:"巨大monorepoで必要なパスだけworktreeにチェックアウト。settings.jsonで指定すると、worktree作成が大幅に高速化する。"},

  // === 8. 新規追加Tips（エージェントA: 公式ドキュメント精査） ===
  {id:123,cat:"prompt",title:"/plan でプロンプト付き計画モード開始",level:"初級",impact:"高",desc:"--permission-mode planの代わりに、プロンプトと一緒に即座に計画モードを開始。「/plan 認証バグを修正して」のように使う。変更を伴わない安全な計画立案に。",code:"/plan 認証バグの修正方針を立てて"},
  {id:124,cat:"ui",title:"/fast でFast Mode即切替",level:"初級",impact:"中",desc:"高速モードをスラッシュコマンドで即座にON/OFF。Alt+Oと同じ効果だが、コマンド入力に慣れている人向け。品質は変わらず速度だけ向上。",code:"/fast"},
  {id:125,cat:"workflow",title:"/recap でセッション概要を手動生成",level:"初級",impact:"中",desc:"長時間離席後に「今どこまで作業したか」を1文で要約表示。自動要約とは別に、任意のタイミングで手動実行も可能。",code:"/recap"},
  {id:126,cat:"hidden",title:"/release-notes で変更履歴を確認",level:"初級",impact:"低",desc:"Claude Codeのバージョン別変更履歴をピッカー形式で参照。新機能の発見や、アップデート後の動作変更の確認に。",code:"/release-notes"},
  {id:127,cat:"ui",title:"/powerup で対話的機能チュートリアル",level:"初級",impact:"中",desc:"アニメーション付きの対話的チュートリアルで新機能を学べる。Claude Code初心者の機能探索や、新機能のキャッチアップに最適。",code:"/powerup"},
  {id:128,cat:"config",title:"/less-permission-prompts で権限プロンプト削減",level:"中級",impact:"高",desc:"過去のセッションで頻繁に許可した読み取り専用操作を自動で許可リストに追加。毎回の「許可しますか？」プロンプトが大幅に減少する。",code:"/less-permission-prompts"},
  {id:129,cat:"config",title:"claude update でCLI自動更新",level:"初級",impact:"高",desc:"Claude Code CLIを最新バージョンに自動アップデート。新機能やバグ修正を即座に適用。--versionで現在のバージョンを事前確認。",code:"claude update"},
  {id:130,cat:"external",title:"claude setup-token でCI用トークン生成",level:"中級",impact:"高",desc:"OAuth長期有効トークンを生成してCI/CDパイプラインに設定。GitHub ActionsやJenkins等でClaude Codeを認証するために必要。",code:"claude setup-token"},
  {id:131,cat:"workflow",title:"--from-pr でPR関連セッションを再開",level:"中級",impact:"高",desc:"PR番号を指定してそのPRに関連するセッションを自動検索・再開。PRレビュー中の修正作業をスムーズに続行できる。",code:"claude --from-pr 123"},
  {id:132,cat:"config",title:"--fallback-model で自動フォールバック",level:"上級",impact:"中",desc:"デフォルトモデルが過負荷時に別モデルに自動切替。CI/CDスクリプトでの安定稼働に重要。",code:'claude -p --fallback-model sonnet "query"'},
  {id:133,cat:"workflow",title:"Agent Teams で複数エージェント並列定義",level:"上級",impact:"高",desc:"/agentsで複数の専門エージェント（reviewer, implementer, tester等）を定義し、並列で分析・実装。複雑なタスクの分業に最適。",code:"/agents"},
  {id:134,cat:"ui",title:"Ctrl+J で改行（全ターミナル対応）",level:"初級",impact:"高",desc:"Shift+Enterと同様に改行を追加できる汎用キー。すべてのターミナルで動作が保証されている最も確実な複数行入力方法。"},

  // === 9. 新規追加Tips（エージェントB: ヘビーユーザー視点） ===
  {id:135,cat:"workflow",title:"複数プロジェクト間のコンテキスト予算管理",level:"中級",impact:"高",desc:"複数プロジェクトを日替わりで進行する場合、セッション分割が重要。高優先度プロジェクトは独立セッション（フルコンテキスト）、低優先度は/compactで効率化するパターン。"},
  {id:136,cat:"workflow",title:"大量生成タスクの /batch + /loop 使い分け",level:"上級",impact:"高",desc:"100個以上の独立ファイル生成には/batchで並列化、品質チェック必須の生成には/loopで段階実行。「バッチで生成→ループで検証」のハイブリッドが実績的に最適。"},
  {id:137,cat:"prompt",title:"Glob→Grepの2段階検索で高速化",level:"中級",impact:"高",desc:"大規模コードベースでは「まずGlobで対象ファイルを絞る→Grepで詳細検索」の2段階が高速。全ファイルフルスキャンより数倍速い。",code:'> 「*.tsファイルの中から\n>  "deprecated" を含む箇所を検索して」'},
  {id:138,cat:"trouble",title:"長時間セッション(5h+)のcompact戦略",level:"上級",impact:"高",desc:"5-6時間の連続作業でコンテキストが圧迫される前に、手動で/compactを実行。重要情報をCLAUDE.mdに移しておくと、compact後も確実に保持される。"},
  {id:139,cat:"workflow",title:"PR規模別の /review vs /ultrareview 選択",level:"中級",impact:"高",desc:"200行未満の小さなPRは/reviewで高速レビュー。200行以上や複雑な変更は/ultrareviewで多角的な深いレビュー。コストと品質のバランスを取る。"},
  {id:140,cat:"prompt",title:"Extended Thinkingで複雑な問題の品質向上",level:"中級",impact:"高",desc:"Alt+TでExtended ThinkingをONにすると、設計判断・アルゴリズム選択・根本原因分析等で思考の深さが格段に向上。通常タスクはOFFでトークン節約。"},
  {id:141,cat:"hidden",title:"Glob+Grepの型指定でファイル絞り込み",level:"中級",impact:"中",desc:"Grepのtype指定（js, py, rust等）やglob指定（*.tsx）でファイル種別を絞り込むと、検索が高速化し、関係ないファイルのノイズも除去できる。"},

  // === 10. 新規追加Tips（エージェントC: 非エンジニア向け） ===
  {id:142,cat:"ui",title:"初めてのClaude Code：起動から最初の操作まで",level:"初級",impact:"高",desc:"ターミナルで「claude」と入力→Enter→プロンプトが表示されたら日本語で依頼→結果確認→ファイル変更時はY/Nで承認。この基本フローを覚えるだけで使い始められる。",code:"$ claude\n> 自己紹介を100文字で書いて"},
  {id:143,cat:"prompt",title:"日本語でのファイル操作指示パターン集",level:"初級",impact:"高",desc:"「〜を読んで」「〜から〜を抽出して」「〜形式で新規作成して」等、ビジネス作業で頻出する指示パターン。日本語で自然に依頼するだけでファイル操作が完了する。",code:"sales_data.csv を読んで、\n売上100万円以上の顧客だけ抽出して"},
  {id:144,cat:"prompt",title:"日本語プロンプトを正確に伝える3つのコツ",level:"初級",impact:"高",desc:"1.何をして欲しいか 2.どのファイルに対してか 3.完成イメージは何か の3点セットで伝える。曖昧な「これを修正して」ではなく「A1:D10の日付をYYYY-MM-DD形式に統一して」のように具体的に。"},
  {id:145,cat:"trouble",title:"初心者がやりがちな5つの失敗パターン",level:"初級",impact:"高",desc:"1.対象ファイル未指定で全ファイル変更 2.指示が曖昧で意図と違う結果 3.承認前に確認しない 4./compactせずにコンテキスト切れ 5.大事なファイルのバックアップなし。各対策を知るだけで事故が激減。"},
  {id:146,cat:"workflow",title:"コード不要で使えるユースケース10選",level:"初級",impact:"高",desc:"CSVデータの重複排除、議事録からToDoリスト抽出、テンプレート一括生成、ファイル名一括変更、メール文案作成、競合比較表作成など。プログラミング知識ゼロでも業務効率化が可能。"},
  {id:147,cat:"prompt",title:"Excel/CSVデータ処理の実践パターン",level:"初級",impact:"高",desc:"「このCSVを部門別に集計して」「重複を削除して」「A列とB列をマージして」等のデータ処理を日本語で依頼するだけ。Excelを開かずにデータクリーニングが完了する。",code:"expense.csv を読んで、\n部署別・費目別に集計表を作成して"},
  {id:148,cat:"ui",title:"Claude.ai（チャット）vs Claude Code の使い分け",level:"初級",impact:"高",desc:"Claude.ai＝質問・相談・考察向き（ブレスト、文章校正等）。Claude Code＝ファイル加工・自動化・出力生成向き（CSV処理、レポート生成等）。実ファイルを扱うならClaude Code。"},
  {id:149,cat:"config",title:"ビジネス職が知るべきセキュリティ3点",level:"初級",impact:"高",desc:"1.パスワード・APIキーを含むファイルを渡さない 2.個人情報（氏名・電話番号等）は匿名化してから処理 3.deny設定でcurlや.envアクセスをブロック。この3点で安全に利用できる。"},
  {id:150,cat:"ui",title:"Claude Codeの「できる/できない」境界線",level:"初級",impact:"高",desc:"できる：ローカルファイルの読み書き・加工、テキスト/データ整形、コード生成・修正。制限あり：外部API呼び出し（要MCP）、メール送信（要設定）。できない：リアルタイムデータ取得、GUI操作（Puppeteer除く）。"},
];

const STORAGE_KEY = 'cca-tips-favs';
const catLabels = {all:"すべて",ui:"UI・操作",prompt:"プロンプト",workflow:"ワークフロー",config:"設定",external:"外部連携",trouble:"トラブル",hidden:"隠れ機能"};
const levelColors = {"初級":"bg-green-100 text-green-700","中級":"bg-blue-100 text-blue-700","上級":"bg-purple-100 text-purple-700"};
const impactColors = {"高":"bg-red-50 text-red-600 border-red-200","中":"bg-yellow-50 text-yellow-600 border-yellow-200","低":"bg-gray-50 text-gray-500 border-gray-200"};

let favs = new Set();
try { const raw = localStorage.getItem(STORAGE_KEY); if (raw) favs = new Set(JSON.parse(raw)); } catch {}

let currentCat = 'all', currentLevel = 'all', currentImpact = 'all', searchQuery = '', showFavsOnly = false;

function saveFavs() { localStorage.setItem(STORAGE_KEY, JSON.stringify([...favs])); }

function getFiltered() {
  return TIPS.filter(t => {
    if (currentCat !== 'all' && t.cat !== currentCat) return false;
    if (currentLevel !== 'all' && t.level !== currentLevel) return false;
    if (currentImpact !== 'all' && t.impact !== currentImpact) return false;
    if (showFavsOnly && !favs.has(t.id)) return false;
    if (searchQuery) {
      const q = searchQuery.toLowerCase();
      return t.title.toLowerCase().includes(q) || t.desc.toLowerCase().includes(q) || (t.code && t.code.toLowerCase().includes(q));
    }
    return true;
  });
}

function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function renderCard(t) {
  const isFav = favs.has(t.id);
  const codeBlock = t.code ? `<div class="mt-3 bg-gray-900 rounded-lg p-3"><code class="text-[11px] text-green-400 font-mono leading-relaxed whitespace-pre-wrap">${escapeHtml(t.code)}</code></div>` : '';
  return `<div class="tip-card bg-white rounded-[10px] border border-base-border p-5" data-id="${t.id}">
    <div class="flex items-start justify-between gap-3 mb-2">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-[10px] px-2 py-0.5 rounded-full ${levelColors[t.level]}">${t.level}</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full border ${impactColors[t.impact]}">効果: ${t.impact}</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-base-muted text-gray-500">#${t.id}</span>
      </div>
      <button class="fav-btn shrink-0 w-8 h-8 flex items-center justify-center rounded-full border border-base-border text-base cursor-pointer transition-all hover:bg-yellow-50 ${isFav ? 'bg-yellow-50 border-yellow-300 text-yellow-500' : 'bg-white text-gray-300'}" data-id="${t.id}" title="お気に入り">${isFav ? '&#9733;' : '&#9734;'}</button>
    </div>
    <h3 class="text-sm font-semibold text-gray-900 mb-1.5">${escapeHtml(t.title)}</h3>
    <p class="text-xs text-gray-600 leading-relaxed">${escapeHtml(t.desc)}</p>
    ${codeBlock}
  </div>`;
}

function render() {
  const filtered = getFiltered();
  const grid = document.getElementById('tips-grid');
  const noRes = document.getElementById('no-results');
  if (filtered.length === 0) { grid.innerHTML = ''; noRes.classList.remove('hidden'); }
  else { grid.innerHTML = filtered.map(renderCard).join(''); noRes.classList.add('hidden'); }

  // 統計更新
  document.getElementById('stat-total').textContent = TIPS.length;
  document.getElementById('stat-showing').textContent = filtered.length;
  document.getElementById('stat-favs').textContent = favs.size;
  document.getElementById('stat-high').textContent = TIPS.filter(t=>t.impact==='高').length;

  // カテゴリ件数
  const cats = {all:TIPS.length, ui:0, prompt:0, workflow:0, config:0, external:0, trouble:0, hidden:0};
  TIPS.forEach(t => cats[t.cat]++);
  Object.keys(cats).forEach(c => { const el = document.getElementById('cnt-'+c); if (el) el.textContent = '('+cats[c]+')'; });

  // お気に入りボタン
  grid.querySelectorAll('.fav-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = Number(btn.dataset.id);
      if (favs.has(id)) { favs.delete(id); btn.innerHTML = '&#9734;'; btn.classList.remove('bg-yellow-50','border-yellow-300','text-yellow-500'); btn.classList.add('bg-white','text-gray-300'); }
      else { favs.add(id); btn.innerHTML = '&#9733;'; btn.classList.add('bg-yellow-50','border-yellow-300','text-yellow-500'); btn.classList.remove('bg-white','text-gray-300'); }
      saveFavs();
      document.getElementById('stat-favs').textContent = favs.size;
      if (showFavsOnly) render();
    });
  });
}

// カテゴリタブ
document.querySelectorAll('.cat-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    currentCat = tab.dataset.cat;
    render();
  });
});

// 難易度フィルター
document.querySelectorAll('.filter-level').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-level').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentLevel = btn.dataset.level;
    render();
  });
});

// 効果度フィルター
document.querySelectorAll('.filter-impact').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-impact').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentImpact = btn.dataset.impact;
    render();
  });
});

// 検索
const searchInput = document.getElementById('search-input');
let searchTimer;
searchInput.addEventListener('input', () => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => { searchQuery = searchInput.value.trim(); render(); }, 200);
});

// お気に入りフィルター
const favFilter = document.getElementById('fav-filter');
favFilter.addEventListener('click', () => {
  showFavsOnly = !showFavsOnly;
  favFilter.classList.toggle('fav-active', showFavsOnly);
  render();
});

// リセット
document.getElementById('reset-filters').addEventListener('click', () => {
  currentCat = 'all'; currentLevel = 'all'; currentImpact = 'all'; searchQuery = ''; showFavsOnly = false;
  searchInput.value = '';
  document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
  document.querySelector('.cat-tab[data-cat="all"]').classList.add('active');
  document.querySelectorAll('.filter-level').forEach(b => b.classList.remove('active'));
  document.querySelector('.filter-level[data-level="all"]').classList.add('active');
  document.querySelectorAll('.filter-impact').forEach(b => b.classList.remove('active'));
  document.querySelector('.filter-impact[data-impact="all"]').classList.add('active');
  favFilter.classList.remove('fav-active');
  render();
});

// 初回描画
render();
</script>
