---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<Layout title="Tips & テクニック集 — Claude Code Academy">
  <Sidebar currentTrack="" currentPage="tips" />

  <main class="ml-[260px] p-8 min-h-screen">
    <div class="mb-7">
      <h1 class="text-[22px] font-semibold text-gray-900">Tips & テクニック集</h1>
      <p class="text-sm text-gray-400 mt-1">Claude Codeの120個のTips · カテゴリ別・難易度別に検索</p>
    </div>

    <!-- 統計カード -->
    <div class="grid grid-cols-4 gap-3.5 mb-7" id="tips-stats">
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">全Tips</div>
        <div class="text-lg font-semibold text-gray-900" id="stat-total">120</div>
      </div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">表示中</div>
        <div class="text-lg font-semibold text-primary" id="stat-showing">120</div>
      </div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">お気に入り</div>
        <div class="text-lg font-semibold text-yellow-500" id="stat-favs">0</div>
      </div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">効果度「高」</div>
        <div class="text-lg font-semibold text-success-dark" id="stat-high">0</div>
      </div>
    </div>

    <!-- 検索 & フィルター -->
    <div class="bg-white rounded-[10px] border border-base-border p-4 mb-5">
      <div class="flex items-center gap-3 mb-3">
        <input type="text" id="search-input" placeholder="キーワードで検索..." class="flex-1 px-3 py-2 border border-base-border rounded-lg text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
        <button id="fav-filter" class="px-3 py-2 border border-base-border rounded-lg text-sm hover:bg-yellow-50 hover:border-yellow-300 transition-all cursor-pointer bg-white" title="お気に入りのみ表示">
          <span class="mr-1">&#9734;</span>お気に入り
        </button>
      </div>

      <!-- 難易度フィルター -->
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[11px] text-gray-400 w-14 shrink-0">難易度:</span>
        <button class="filter-level active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-level="all">すべて</button>
        <button class="filter-level px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-level="初級">初級</button>
        <button class="filter-level px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-level="中級">中級</button>
        <button class="filter-level px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-level="上級">上級</button>
      </div>

      <!-- 効果度フィルター -->
      <div class="flex items-center gap-2">
        <span class="text-[11px] text-gray-400 w-14 shrink-0">効果度:</span>
        <button class="filter-impact active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-impact="all">すべて</button>
        <button class="filter-impact px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-impact="高">高</button>
        <button class="filter-impact px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-impact="中">中</button>
        <button class="filter-impact px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-impact="低">低</button>
      </div>
    </div>

    <!-- カテゴリタブ -->
    <div class="flex gap-1 mb-5 overflow-x-auto pb-1" id="cat-tabs">
      <button class="cat-tab active whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="all">すべて<span class="ml-1 text-gray-400" id="cnt-all"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="ui">UI・操作<span class="ml-1 text-gray-400" id="cnt-ui"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="prompt">プロンプト<span class="ml-1 text-gray-400" id="cnt-prompt"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="workflow">ワークフロー<span class="ml-1 text-gray-400" id="cnt-workflow"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="config">設定<span class="ml-1 text-gray-400" id="cnt-config"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="external">外部連携<span class="ml-1 text-gray-400" id="cnt-external"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="trouble">トラブル<span class="ml-1 text-gray-400" id="cnt-trouble"></span></button>
      <button class="cat-tab whitespace-nowrap px-3 py-2 rounded-lg text-[12px] font-medium border cursor-pointer transition-all" data-cat="hidden">隠れ機能<span class="ml-1 text-gray-400" id="cnt-hidden"></span></button>
    </div>

    <!-- Tips カード一覧 -->
    <div id="tips-grid" class="grid grid-cols-1 gap-3">
    </div>

    <!-- 0件メッセージ -->
    <div id="no-results" class="hidden text-center py-16">
      <div class="text-4xl mb-3">🔍</div>
      <p class="text-sm text-gray-500">条件に一致するTipsが見つかりませんでした</p>
      <button id="reset-filters" class="mt-3 px-4 py-2 bg-primary text-white rounded-lg text-sm cursor-pointer hover:bg-primary-dark transition-colors border-none">フィルターをリセット</button>
    </div>
  </main>
</Layout>

<style>
  .cat-tab.active { background-color: var(--color-primary-bg); color: var(--color-primary); border-color: var(--color-primary-border); }
  .cat-tab:not(.active) { background-color: white; color: #6b7280; border-color: var(--color-base-border); }
  .cat-tab:not(.active):hover { background-color: var(--color-primary-bg); }
  .filter-level.active, .filter-impact.active { background-color: var(--color-primary-bg); color: var(--color-primary); border-color: var(--color-primary-border); }
  .filter-level:not(.active), .filter-impact:not(.active) { background-color: white; color: #6b7280; border-color: var(--color-base-border); }
  .filter-level:not(.active):hover, .filter-impact:not(.active):hover { background-color: #f9fafb; }
  .fav-active { background-color: #fef9c3 !important; border-color: #facc15 !important; color: #a16207 !important; }
  .tip-card { transition: all 0.15s ease; }
  .tip-card:hover { border-color: var(--color-primary-pale); box-shadow: 0 2px 8px rgba(83,74,183,0.08); }
</style>

<script>
const TIPS = [
  // === 1. UI・操作系 (19) ===
  {id:1,cat:"ui",title:"Shift+Tab でPermission mode即切替",level:"初級",impact:"高",desc:"Ask → Auto Edit → Full Auto をワンキーで切替。作業フェーズに応じて瞬時に変更できる。"},
  {id:2,cat:"ui",title:"Ctrl+R でコマンド履歴を逆検索",level:"初級",impact:"中",desc:"過去のプロンプトをインクリメンタル検索。同じ指示の再利用が高速になる。"},
  {id:3,cat:"ui",title:"Ctrl+O でトランスクリプトビューア表示",level:"中級",impact:"高",desc:"ツール呼び出しの詳細ログを確認。Claude Codeの内部動作（どのツールをどの順で使ったか）が丸見えになる。"},
  {id:4,cat:"ui",title:"バックスラッシュ+Enter で複数行入力",level:"初級",impact:"高",desc:"全ターミナル対応の改行方法。長いプロンプトを構造化して入力できる。Shift+Enterが効かない環境でも使える。"},
  {id:5,cat:"ui",title:"Ctrl+V で画像をクリップボードから貼付",level:"中級",impact:"高",desc:"スクリーンショットやUI画像を直接貼り付けてレビュー依頼。エラー画面のスクショを貼って「これを修正して」が可能。"},
  {id:6,cat:"ui",title:"Ctrl+B でバックグラウンドタスク実行",level:"中級",impact:"中",desc:"長時間ビルドやテストをバックグラウンドで実行しながら別作業を続行できる。"},
  {id:7,cat:"ui",title:"Ctrl+T でタスクリスト表示/非表示",level:"中級",impact:"中",desc:"バックグラウンドタスクの進捗をリアルタイムで確認。"},
  {id:8,cat:"ui",title:"Alt+P でモデルを即切替",level:"中級",impact:"高",desc:"Opus ↔ Sonnet ↔ Haiku をキー一つで切替。重いタスクはOpus、軽い質問はHaikuで使い分け。",code:"Alt+P (Windows)\nOption+P (macOS)"},
  {id:9,cat:"ui",title:"Alt+T で Extended Thinking を切替",level:"中級",impact:"中",desc:"複雑な推論が必要な時だけONにしてトークン節約。設計やアルゴリズムの検討時に有効。"},
  {id:10,cat:"ui",title:"Alt+O で高速モード（Fast Mode）切替",level:"初級",impact:"中",desc:"同じOpusモデルで高速出力。品質は変わらず速度だけ向上する。"},
  {id:11,cat:"ui",title:"Ctrl+G で外部エディタでプロンプト編集",level:"上級",impact:"低",desc:"VS Code等でプロンプトを編集してから送信。超長文の指示を書く時に便利。"},
  {id:12,cat:"ui",title:"Ctrl+X Ctrl+K で全バックグラウンドエージェント終了",level:"上級",impact:"低",desc:"暴走したサブエージェントを一括停止。2回押しで確認が入る安全設計。"},
  {id:13,cat:"ui",title:"/config → Vim Mode を有効化",level:"中級",impact:"中",desc:"hjkl移動、dd削除、yy/pコピペなどVimキーバインドが使える。Vimmerに必須の設定。"},
  {id:14,cat:"ui",title:"Vim modeとCtrlショートカットは独立動作",level:"中級",impact:"低",desc:"EscでNORMALモードに入るが、Ctrl+O等のショートカットはそのまま併用できる。"},
  {id:15,cat:"ui",title:"VS Code拡張でエディタから直接起動",level:"初級",impact:"高",desc:"Anthropic公式「Claude Code」拡張。ファイルを自動でコンテキストに含み、IDE内でシームレスに作業。"},
  {id:16,cat:"ui",title:"JetBrains拡張で IntelliJ/WebStorm連携",level:"初級",impact:"高",desc:"JetBrains IDE内でClaude Codeを実行。デバッガーとの連携も可能。"},
  {id:17,cat:"ui",title:"Desktop版のSide Chats機能",level:"中級",impact:"中",desc:"メインスレッドに影響なく別質問が可能。設計相談しながら実装を進められる。"},
  {id:18,cat:"ui",title:"Desktop版のLive App Preview",level:"中級",impact:"高",desc:"devサーバー・HTML・PDFをDesktopアプリ内でプレビュー表示。ブラウザに切り替え不要。"},
  {id:19,cat:"ui",title:"Desktop版のVisual Diff Review",level:"中級",impact:"高",desc:"インラインコメント付きの差分ビューア。PRレビューが格段に見やすくなる。"},

  // === 2. プロンプト・指示系 (30) ===
  {id:20,cat:"prompt",title:"/compact [指示] で焦点を絞って圧縮",level:"初級",impact:"高",desc:"「/compact パフォーマンス改善に集中」のように焦点を指定すると、関連情報を優先保持してくれる。",code:"/compact パフォーマンス改善に集中して"},
  {id:21,cat:"prompt",title:"/batch で大規模変更を並列処理",level:"上級",impact:"高",desc:"5〜30個の独立した変更を自動分割・並列実行。大規模リファクタリングの切り札。",code:"/batch 全APIルートにバリデーション追加"},
  {id:22,cat:"prompt",title:"/review でPRレビューを自動実行",level:"初級",impact:"高",desc:"現在のdiffまたは指定PRを自動レビュー。セキュリティ・パフォーマンス・可読性を分析。",code:"/review\n/review 42"},
  {id:23,cat:"prompt",title:"/security-review でセキュリティ監査",level:"中級",impact:"高",desc:"保留中の変更をOWASP Top 10の観点でセキュリティレビュー。",code:"/security-review"},
  {id:24,cat:"prompt",title:"/init でCLAUDE.mdを自動生成",level:"初級",impact:"高",desc:"プロジェクト構造を分析して最適なCLAUDE.mdを自動作成。新規プロジェクトの初期設定に。",code:"/init"},
  {id:25,cat:"prompt",title:"/diff でインタラクティブdiffビューア",level:"中級",impact:"中",desc:"変更内容を視覚的に確認。コミット前の最終チェックに最適。"},
  {id:26,cat:"prompt",title:"/cost でトークン使用量を確認",level:"初級",impact:"中",desc:"セッションのコスト・トークン消費をリアルタイムで把握できる。",code:"/cost"},
  {id:27,cat:"prompt",title:"/context でコンテキスト使用状況を可視化",level:"中級",impact:"中",desc:"何がコンテキストを占有しているか一目で確認。不要な情報の特定に。",code:"/context"},
  {id:28,cat:"prompt",title:"/effort [level] で推論の深さを調整",level:"中級",impact:"中",desc:"low/medium/high/xhigh/max の5段階。簡単なタスクはlowにすると高速化。",code:"/effort low\n/effort max"},
  {id:29,cat:"prompt",title:"/branch で会話をブランチ分岐",level:"上級",impact:"中",desc:"現在の時点から会話を分岐。別のアプローチを試して比較できる。",code:"/branch alternative-approach"},
  {id:30,cat:"prompt",title:"/export で会話をテキスト出力",level:"初級",impact:"低",desc:"テキスト形式でファイルに保存。ナレッジ共有やドキュメント化に。",code:"/export session-log.txt"},
  {id:31,cat:"prompt",title:"/insights でセッション使用分析",level:"中級",impact:"低",desc:"過去のセッション傾向をレポート。使い方の改善ポイントが見える。"},
  {id:32,cat:"prompt",title:"/team-onboarding でチーム用ガイド生成",level:"中級",impact:"中",desc:"チームメンバー向けオンボーディングガイドを自動生成。新メンバーの立ち上げに。"},
  {id:33,cat:"prompt",title:"/simplify でコード品質を自動改善",level:"中級",impact:"中",desc:"変更されたファイルをレビューし、品質を自動で改善してくれる。"},
  {id:34,cat:"prompt",title:"@ファイルパス でファイルを明示参照",level:"初級",impact:"高",desc:"@src/api/auth.ts のように指定。タブ補完が効くので素早く入力できる。",code:"@src/api/auth.ts このファイルをレビューして"},
  {id:35,cat:"prompt",title:"@フォルダ/ でディレクトリ全体を参照",level:"初級",impact:"高",desc:"@src/components/ で関連ファイルをまとめてコンテキストに投入。",code:"@src/components/ 型定義を統一して"},
  {id:36,cat:"prompt",title:"@URL でWebページを参照",level:"中級",impact:"中",desc:"外部ドキュメントやAPI仕様を直接参照して作業に反映。"},
  {id:37,cat:"prompt",title:"! でBashコマンドを直接実行",level:"初級",impact:"中",desc:"プロンプトで「!」をつけるとClaude Codeを経由せず直接コマンド実行。",code:"!git status\n!npm run test"},
  {id:38,cat:"prompt",title:"「テストも書いて」の一文を追加",level:"初級",impact:"高",desc:"修正指示の末尾に「テストも書いて」を加えるだけでTDD的ワークフローに。"},
  {id:39,cat:"prompt",title:"「最小限の変更で」と明示する",level:"初級",impact:"高",desc:"スコープクリープを防ぐ。バグ修正やhotfixで特に重要。"},
  {id:40,cat:"prompt",title:"番号付きステップで段階的に指示",level:"初級",impact:"高",desc:"「1.分析 2.修正 3.テスト 4.レビュー」のように段階を明示すると精度向上。"},
  {id:41,cat:"prompt",title:"「〜の観点で」とレビュー観点を限定",level:"中級",impact:"高",desc:"「パフォーマンスの観点でレビューして」のように焦点を絞ると的確なフィードバックが得られる。"},
  {id:42,cat:"prompt",title:"ネガティブ制約を明示する",level:"中級",impact:"中",desc:"「既存のテストを壊さないで」「新しい依存を追加しないで」等の禁止事項を伝える。"},
  {id:43,cat:"prompt",title:"CLAUDE.mdに @ファイル名 でインポート",level:"中級",impact:"高",desc:"CLAUDE.md内で @README.md @package.json 等を参照。常に最新情報を自動取得。",code:"# CLAUDE.md内\n@README.md\n@docs/api-spec.md"},
  {id:44,cat:"prompt",title:"サブディレクトリにCLAUDE.mdを配置",level:"中級",impact:"中",desc:"src/api/CLAUDE.md のようにモジュール別の指示を配置。そのディレクトリのファイルを読む時に自動適用。"},
  {id:45,cat:"prompt",title:"CLAUDE.local.md で個人設定を分離",level:"中級",impact:"中",desc:".gitignore に入れる個人設定用。チーム共有のCLAUDE.mdと個人の好みを分離できる。"},
  {id:46,cat:"prompt",title:"CLAUDE.mdの4段階優先順位を理解する",level:"上級",impact:"中",desc:"管理者 > プロジェクト > ユーザー > ローカル の順で適用。組織ポリシーは上書きできない設計。"},
  {id:47,cat:"prompt",title:"開発コマンド一覧をCLAUDE.mdに記載",level:"初級",impact:"高",desc:"npm run dev, npm run test 等を書いておくとClaude Codeが正しいコマンドを使ってくれる。"},
  {id:48,cat:"prompt",title:"/debug でデバッグログを有効化",level:"中級",impact:"中",desc:"問題の診断にデバッグログを有効化。原因特定が高速になる。",code:"/debug api connection issue"},
  {id:49,cat:"prompt",title:"/copy [N] で応答をクリップボードコピー",level:"初級",impact:"中",desc:"直前のClaude応答をコピー。Nを指定すると過去N番目の応答をコピー。",code:"/copy\n/copy 3"},

  // === 3. ワークフロー系 (17) ===
  {id:50,cat:"workflow",title:"claude -w でworktree隔離セッション",level:"上級",impact:"高",desc:"自動でgit worktreeを作成し、メインブランチに影響なく作業。複数機能の並列開発に最適。",code:"claude -w feature-auth"},
  {id:51,cat:"workflow",title:"--tmux でtmuxペイン付きworktree",level:"上級",impact:"中",desc:"エディタ・ターミナル・プレビューを分割表示して作業。",code:"claude -w feature --tmux"},
  {id:52,cat:"workflow",title:".worktreeinclude で.envを自動コピー",level:"上級",impact:"高",desc:"gitignoreされた.envファイルをworktreeに自動コピー。環境変数が正しく引き継がれる。",code:"# .worktreeinclude\n.env\n.env.local\nconfig/local.json"},
  {id:53,cat:"workflow",title:"symlinkDirectories でnode_modules共有",level:"上級",impact:"中",desc:"settings.jsonでnode_modulesをシンボリックリンク。ディスク節約＆npm install不要。"},
  {id:54,cat:"workflow",title:"claude -c で最新セッションを即再開",level:"初級",impact:"高",desc:"前回の会話をそのまま続行。朝イチの作業再開に最適。",code:"claude -c"},
  {id:55,cat:"workflow",title:"--resume で名前付きセッション復帰",level:"中級",impact:"高",desc:"/rename でセッションに名前をつけておくと後から探しやすい。",code:"claude --resume auth-refactor"},
  {id:56,cat:"workflow",title:"claude -n でセッション名を指定して開始",level:"中級",impact:"中",desc:"最初から名前をつけて開始。プロジェクト・機能別にセッションを整理。",code:'claude -n "payment-integration"'},
  {id:57,cat:"workflow",title:"/color でセッションの色を変更",level:"初級",impact:"低",desc:"複数ターミナルで作業する際の視覚的区別に。",code:"/color blue"},
  {id:58,cat:"workflow",title:"「並列で実行して」と明示的に指示",level:"中級",impact:"高",desc:"サブエージェントによる並列処理をトリガー。特に調査タスクで効果的。"},
  {id:59,cat:"workflow",title:"「調査→実装」の2フェーズで進める",level:"中級",impact:"高",desc:"Phase1で並列調査、Phase2で結果に基づき順次実装。品質と速度を両立するパターン。"},
  {id:60,cat:"workflow",title:"ディレクトリ単位でタスクを分割",level:"中級",impact:"高",desc:"「src/api/は〜、src/components/は〜」のように分割するとサブエージェントが並列処理しやすい。"},
  {id:61,cat:"workflow",title:"/loop で定期実行タスクを設定",level:"上級",impact:"中",desc:"ビルドやデプロイの監視を自動化。",code:"/loop 5m ビルドが通るか確認して"},
  {id:62,cat:"workflow",title:"claude --remote でクラウドセッション",level:"上級",impact:"高",desc:"Anthropicのクラウド VM上で実行。ローカルに負荷をかけず長時間タスクを処理。",code:'claude --remote "認証バグを修正して"'},
