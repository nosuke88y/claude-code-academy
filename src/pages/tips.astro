const STORAGE_KEY = 'cca-tips-favs';
const catLabels = {all:"すべて",ui:"UI・操作",prompt:"プロンプト",workflow:"ワークフロー",config:"設定",external:"外部連携",trouble:"トラブル",hidden:"隠れ機能"};
const levelColors = {"初級":"bg-green-100 text-green-700","中級":"bg-blue-100 text-blue-700","上級":"bg-purple-100 text-purple-700"};
const impactColors = {"高":"bg-red-50 text-red-600 border-red-200","中":"bg-yellow-50 text-yellow-600 border-yellow-200","低":"bg-gray-50 text-gray-500 border-gray-200"};

let favs = new Set();
try { const raw = localStorage.getItem(STORAGE_KEY); if (raw) favs = new Set(JSON.parse(raw)); } catch {}

let currentCat = 'all', currentLevel = 'all', currentImpact = 'all', searchQuery = '', showFavsOnly = false;

function saveFavs() { localStorage.setItem(STORAGE_KEY, JSON.stringify([...favs])); }

function getFiltered() {
  return TIPS.filter(t => {
    if (currentCat !== 'all' && t.cat !== currentCat) return false;
    if (currentLevel !== 'all' && t.level !== currentLevel) return false;
    if (currentImpact !== 'all' && t.impact !== currentImpact) return false;
    if (showFavsOnly && !favs.has(t.id)) return false;
    if (searchQuery) {
      const q = searchQuery.toLowerCase();
      return t.title.toLowerCase().includes(q) || t.desc.toLowerCase().includes(q) || (t.code && t.code.toLowerCase().includes(q));
    }
    return true;
  });
}

function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function renderCard(t) {
  const isFav = favs.has(t.id);
  const codeBlock = t.code ? `<div class="mt-3 bg-gray-900 rounded-lg p-3"><code class="text-[11px] text-green-400 font-mono leading-relaxed whitespace-pre-wrap">${escapeHtml(t.code)}</code></div>` : '';
  return `<div class="tip-card bg-white rounded-[10px] border border-base-border p-5" data-id="${t.id}">
    <div class="flex items-start justify-between gap-3 mb-2">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-[10px] px-2 py-0.5 rounded-full ${levelColors[t.level]}">${t.level}</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full border ${impactColors[t.impact]}">効果: ${t.impact}</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-base-muted text-gray-500">#${t.id}</span>
      </div>
      <button class="fav-btn shrink-0 w-8 h-8 flex items-center justify-center rounded-full border border-base-border text-base cursor-pointer transition-all hover:bg-yellow-50 ${isFav ? 'bg-yellow-50 border-yellow-300 text-yellow-500' : 'bg-white text-gray-300'}" data-id="${t.id}" title="お気に入り">${isFav ? '&#9733;' : '&#9734;'}</button>
    </div>
    <h3 class="text-sm font-semibold text-gray-900 mb-1.5">${escapeHtml(t.title)}</h3>
    <p class="text-xs text-gray-600 leading-relaxed">${escapeHtml(t.desc)}</p>
    ${codeBlock}
  </div>`;
}

function render() {
  const filtered = getFiltered();
  const grid = document.getElementById('tips-grid');
  const noRes = document.getElementById('no-results');
  if (filtered.length === 0) { grid.innerHTML = ''; noRes.classList.remove('hidden'); }
  else { grid.innerHTML = filtered.map(renderCard).join(''); noRes.classList.add('hidden'); }

  // 統計更新
  document.getElementById('stat-showing').textContent = filtered.length;
  document.getElementById('stat-favs').textContent = favs.size;
  document.getElementById('stat-high').textContent = TIPS.filter(t=>t.impact==='高').length;

  // カテゴリ件数
  const cats = {all:TIPS.length, ui:0, prompt:0, workflow:0, config:0, external:0, trouble:0, hidden:0};
  TIPS.forEach(t => cats[t.cat]++);
  Object.keys(cats).forEach(c => { const el = document.getElementById('cnt-'+c); if (el) el.textContent = '('+cats[c]+')'; });

  // お気に入りボタン
  grid.querySelectorAll('.fav-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = Number(btn.dataset.id);
      if (favs.has(id)) { favs.delete(id); btn.innerHTML = '&#9734;'; btn.classList.remove('bg-yellow-50','border-yellow-300','text-yellow-500'); btn.classList.add('bg-white','text-gray-300'); }
      else { favs.add(id); btn.innerHTML = '&#9733;'; btn.classList.add('bg-yellow-50','border-yellow-300','text-yellow-500'); btn.classList.remove('bg-white','text-gray-300'); }
      saveFavs();
      document.getElementById('stat-favs').textContent = favs.size;
      if (showFavsOnly) render();
    });
  });
}

// カテゴリタブ
document.querySelectorAll('.cat-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    currentCat = tab.dataset.cat;
    render();
  });
});

// 難易度フィルター
document.querySelectorAll('.filter-level').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-level').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentLevel = btn.dataset.level;
    render();
  });
});

// 効果度フィルター
document.querySelectorAll('.filter-impact').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-impact').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentImpact = btn.dataset.impact;
    render();
  });
});

// 検索
const searchInput = document.getElementById('search-input');
let searchTimer;
searchInput.addEventListener('input', () => {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => { searchQuery = searchInput.value.trim(); render(); }, 200);
});

// お気に入りフィルター
const favFilter = document.getElementById('fav-filter');
favFilter.addEventListener('click', () => {
  showFavsOnly = !showFavsOnly;
  favFilter.classList.toggle('fav-active', showFavsOnly);
  render();
});

// リセット
document.getElementById('reset-filters').addEventListener('click', () => {
  currentCat = 'all'; currentLevel = 'all'; currentImpact = 'all'; searchQuery = ''; showFavsOnly = false;
  searchInput.value = '';
  document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
  document.querySelector('.cat-tab[data-cat="all"]').classList.add('active');
  document.querySelectorAll('.filter-level').forEach(b => b.classList.remove('active'));
  document.querySelector('.filter-level[data-level="all"]').classList.add('active');
  document.querySelectorAll('.filter-impact').forEach(b => b.classList.remove('active'));
  document.querySelector('.filter-impact[data-impact="all"]').classList.add('active');
  favFilter.classList.remove('fav-active');
  render();
});

// 初回描画
render();
</script>
