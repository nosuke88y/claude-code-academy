---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import LessonContent1 from '../../components/lessons/LessonContent1.astro';
import LessonContent2 from '../../components/lessons/LessonContent2.astro';
import LessonContent3 from '../../components/lessons/LessonContent3.astro';
import LessonContent4 from '../../components/lessons/LessonContent4.astro';

const lessonData = {
  "ch1-l1": { chapter: "Ch.1", title: "AIコーディングとは？従来との違い", type: "読み物", duration: "約8分", prev: null, next: "ch1-l2" },
  "ch1-l2": { chapter: "Ch.1", title: "Claude Codeのアーキテクチャ概観", type: "解説", duration: "約8分", prev: "ch1-l1", next: "ch1-l3" },
  "ch1-l3": { chapter: "Ch.1", title: "ユースケース別活用マップ", type: "インタラクティブ", duration: "約7分", prev: "ch1-l2", next: "ch1-l4" },
  "ch1-l4": { chapter: "Ch.1", title: "理解度チェックテスト", type: "クイズ", duration: "約7分", prev: "ch1-l3", next: null },
};

export function getStaticPaths() {
  return [
    { params: { id: "ch1-l1" } },
    { params: { id: "ch1-l2" } },
    { params: { id: "ch1-l3" } },
    { params: { id: "ch1-l4" } },
  ];
}

const { id } = Astro.params;
const lesson = lessonData[id] || { chapter: "Ch.1", title: "レッスン", type: "", duration: "", prev: null, next: null };
const chId = id.split('-')[0];
const lId = id.split('-')[1];
---

<Layout title={`${lesson.title} — Claude Code Academy`}>
  <Sidebar />

  <main class="ml-[260px] p-8 min-h-screen">
    <!-- パンくず -->
    <div class="flex items-center gap-2 text-xs text-gray-400 mb-6">
      <a href="/" class="hover:text-primary transition-colors no-underline text-gray-400">ホーム</a>
      <span>/</span>
      <span>{lesson.chapter}</span>
      <span>/</span>
      <span class="text-gray-600">{lesson.title}</span>
    </div>

    <!-- メタ情報 -->
    <div class="flex items-center gap-2 mb-3">
      <span class="text-[11px] px-2.5 py-0.5 rounded-full bg-primary-bg text-primary">{lesson.chapter}</span>
      <span class="text-[11px] px-2.5 py-0.5 rounded-full bg-base-muted text-gray-500">{lesson.type}</span>
      <span class="text-[11px] px-2.5 py-0.5 rounded-full bg-base-muted text-gray-500">{lesson.duration}</span>
    </div>

    <h1 class="text-2xl font-semibold text-gray-900 mb-6">{lesson.title}</h1>

    <!-- レッスンコンテンツ -->
    {id === "ch1-l1" && <LessonContent1 />}
    {id === "ch1-l2" && <LessonContent2 />}
    {id === "ch1-l3" && <LessonContent3 />}
    {id === "ch1-l4" && <LessonContent4 />}

    <!-- 完了ボタン + ナビゲーション（l4以外） -->
    {id !== "ch1-l4" && (
      <div class="max-w-3xl mt-8 border-t border-base-border pt-6" id="lesson-footer" data-ch={chId} data-lesson={lId}>
        <button
          id="complete-btn"
          class="w-full py-3 bg-primary text-white border-none rounded-lg text-sm font-medium cursor-pointer hover:bg-primary-dark transition-colors mb-4"
        >
          このレッスンを完了する（+20 XP）
        </button>
        <div id="completed-msg" class="w-full py-3 bg-success-bg text-success-dark rounded-lg text-sm font-medium text-center mb-4 hidden">
          ✅ このレッスンは完了済みです
        </div>

        <div class="flex items-center justify-between">
          {lesson.prev ? (
            <a href={`/lesson/${lesson.prev}`} class="px-5 py-2.5 bg-transparent text-primary border border-primary-border rounded-lg text-sm no-underline hover:bg-primary-bg transition-all">← 前のレッスン</a>
          ) : <div />}
          {lesson.next ? (
            <a href={`/lesson/${lesson.next}`} class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-medium no-underline hover:bg-primary-dark transition-colors">次のレッスン →</a>
          ) : (
            <a href="/" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-medium no-underline hover:bg-primary-dark transition-colors">コースに戻る</a>
          )}
        </div>
      </div>
    )}
  </main>
</Layout>

<script>
  // レッスン完了ボタンの処理（l4以外のレッスン用）
  const footer = document.getElementById('lesson-footer');
  if (footer) {
    const STORAGE_KEY = 'cca-progress';
    const chId = footer.dataset.ch;
    const lId = footer.dataset.lesson;

    function loadProgress() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { chapters: {}, xp: 0, level: 1, streak: 0, lastStudyDate: null };
        return { chapters: {}, xp: 0, level: 1, streak: 0, lastStudyDate: null, ...JSON.parse(raw) };
      } catch { return { chapters: {}, xp: 0, level: 1, streak: 0, lastStudyDate: null }; }
    }

    function isCompleted() {
      const data = loadProgress();
      return !!data.chapters?.[chId]?.lessons?.[lId]?.completed;
    }

    function completeLesson() {
      const data = loadProgress();
      if (!data.chapters[chId]) data.chapters[chId] = { lessons: {} };
      data.chapters[chId].lessons[lId] = { completed: true, completedAt: new Date().toISOString() };
      data.xp += 20;
      data.level = Math.floor(data.xp / 200) + 1;
      const today = new Date().toISOString().slice(0, 10);
      if (data.lastStudyDate !== today) {
        const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
        data.streak = data.lastStudyDate === yesterday ? data.streak + 1 : 1;
        data.lastStudyDate = today;
      }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    }

    const btn = document.getElementById('complete-btn');
    const msg = document.getElementById('completed-msg');

    if (isCompleted()) {
      btn.classList.add('hidden');
      msg.classList.remove('hidden');
    }

    btn.addEventListener('click', () => {
      completeLesson();
      btn.classList.add('hidden');
      msg.classList.remove('hidden');
    });
  }
</script>
