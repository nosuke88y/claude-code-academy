import LessonContent7 from '../../components/lessons/LessonContent7.astro';
import LessonContent8 from '../../components/lessons/LessonContent8.astro';
import LessonContent9 from '../../components/lessons/LessonContent9.astro';
import LessonContent10 from '../../components/lessons/LessonContent10.astro';
import LessonContent11 from '../../components/lessons/LessonContent11.astro';
import LessonContent12 from '../../components/lessons/LessonContent12.astro';
import LessonContent13 from '../../components/lessons/LessonContent13.astro';
import LessonContent14 from '../../components/lessons/LessonContent14.astro';
