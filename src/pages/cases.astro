{t:"技術リサーチ時間を80%削減",job:"eng",cat:"data",lv:"初級",before:"新フレームワーク・ライブラリの調査に1時間以上のGoogle検索",how:"自然言語でリサーチを依頼、ドキュメント検索・要約を自動化",after:"1時間→10-20分（80%削減）",pct:"80",tags:["基本操作"],src:"Anthropic全職種",link:"/tips"},
];

const catL={"all":"すべて","dev":"開発効率化","auto":"業務自動化","data":"データ分析","content":"コンテンツ"};
const catC={"dev":"bg-blue-100 text-blue-700","auto":"bg-green-100 text-green-700","data":"bg-purple-100 text-purple-700","content":"bg-orange-100 text-orange-700"};
const jobL={"eng":"エンジニア","biz":"ビジネス職","non":"非エンジニア"};
const jobC={"eng":"bg-yellow-50 text-yellow-700","biz":"bg-primary-bg text-primary","non":"bg-pink-50 text-pink-700"};
const lvC={"初級":"bg-green-100 text-green-700","中級":"bg-blue-100 text-blue-700","上級":"bg-purple-100 text-purple-700"};

let fCat='all',fJob='all',fLv='all',q='';

function render(){
  const f=D.filter(c=>{
    if(fCat!=='all'&&c.cat!==fCat)return false;
    if(fJob!=='all'&&c.job!==fJob)return false;
    if(fLv!=='all'&&c.lv!==fLv)return false;
    if(q){const s=q.toLowerCase();return c.t.toLowerCase().includes(s)||c.before.toLowerCase().includes(s)||c.how.toLowerCase().includes(s)||c.after.toLowerCase().includes(s)||c.src.toLowerCase().includes(s);}
    return true;
  });
  document.getElementById('s-showing').textContent=f.length;
  document.getElementById('s-total').textContent=D.length;
  document.getElementById('s-beg').textContent=D.filter(c=>c.lv==='初級').length;
  const el=document.getElementById('case-list'),no=document.getElementById('no-results');
  if(!f.length){el.innerHTML='';no.classList.remove('hidden');return;}
  no.classList.add('hidden');
  el.innerHTML=f.map(c=>`<div class="bg-white rounded-[10px] border border-base-border p-5 hover:border-primary-pale hover:shadow-[0_2px_8px_rgba(83,74,183,0.08)] transition-all">
    <div class="flex items-start justify-between gap-3 mb-3">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-[10px] px-2 py-0.5 rounded-full ${catC[c.cat]}">${catL[c.cat]}</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full ${jobC[c.job]}">${jobL[c.job]}</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full ${lvC[c.lv]}">${c.lv}</span>
      </div>
      ${c.pct?`<div class="text-lg font-bold text-success-dark shrink-0">-${c.pct}%</div>`:''}
    </div>
    <h3 class="text-sm font-semibold text-gray-900 mb-2">${c.t}</h3>
    <div class="grid grid-cols-[1fr_auto_1fr] gap-2 mb-3 text-xs">
      <div class="bg-red-50 rounded-lg p-2.5 border border-red-100">
        <div class="text-[10px] text-red-400 font-medium mb-1">Before</div>
        <div class="text-gray-700">${c.before}</div>
      </div>
      <div class="flex items-center text-gray-300 text-lg">→</div>
      <div class="bg-green-50 rounded-lg p-2.5 border border-green-100">
        <div class="text-[10px] text-green-500 font-medium mb-1">After</div>
        <div class="text-gray-700 font-medium">${c.after}</div>
      </div>
    </div>
    <p class="text-xs text-gray-500 mb-3"><span class="font-medium text-gray-600">How:</span> ${c.how}</p>
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-1 flex-wrap">
        ${c.tags.map(tag=>`<span class="text-[9px] px-1.5 py-0.5 rounded bg-base-muted text-gray-500">${tag}</span>`).join('')}
        <span class="text-[10px] text-gray-400 ml-1">${c.src}</span>
      </div>
      <a href="${c.link}" class="text-[11px] text-primary font-medium no-underline hover:underline shrink-0">学習する →</a>
    </div>
  </div>`).join('');
}

// フィルター
document.querySelectorAll('.cf').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.cf').forEach(x=>x.classList.remove('active'));b.classList.add('active');fCat=b.dataset.cat;render();});});
document.querySelectorAll('.jf').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.jf').forEach(x=>x.classList.remove('active'));b.classList.add('active');fJob=b.dataset.job;render();});});
document.querySelectorAll('.lf').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.lf').forEach(x=>x.classList.remove('active'));b.classList.add('active');fLv=b.dataset.lv;render();});});
let st;document.getElementById('search').addEventListener('input',e=>{clearTimeout(st);st=setTimeout(()=>{q=e.target.value.trim();render();},200);});
render();
</script>
