---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<Layout title="活用事例集 — Claude Code Academy">
  <Sidebar currentPage="cases" />
  <main class="ml-[260px] p-8 min-h-screen">
    <div class="mb-7">
      <h1 class="text-[22px] font-semibold text-gray-900">活用事例集</h1>
      <p class="text-sm text-gray-400 mt-1">実際の企業・個人によるClaude Code活用事例 · 35件 · Web検索で収集</p>
    </div>

    <!-- 統計 -->
    <div class="grid grid-cols-4 gap-3.5 mb-7">
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">事例数</div>
        <div class="text-lg font-semibold text-gray-900" id="s-total">35</div>
      </div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">表示中</div>
        <div class="text-lg font-semibold text-primary" id="s-showing">35</div>
      </div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">平均削減率</div>
        <div class="text-lg font-semibold text-success-dark">78%</div>
      </div>
      <div class="bg-white rounded-[10px] border border-base-border px-4 py-3.5">
        <div class="text-xs text-gray-400 mb-0.5">初級向け</div>
        <div class="text-lg font-semibold text-green-600" id="s-beg">0</div>
      </div>
    </div>

    <!-- フィルター -->
    <div class="bg-white rounded-[10px] border border-base-border p-4 mb-5">
      <div class="flex items-center gap-3 mb-3">
        <input type="text" id="search" placeholder="キーワードで検索..." class="flex-1 px-3 py-2 border border-base-border rounded-lg text-sm focus:outline-none focus:border-primary" />
      </div>
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[11px] text-gray-400 w-16 shrink-0">カテゴリ:</span>
        <button class="cf active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-cat="all">すべて</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-cat="dev">開発効率化</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-cat="auto">業務自動化</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-cat="data">データ分析</button>
        <button class="cf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-cat="content">コンテンツ</button>
      </div>
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[11px] text-gray-400 w-16 shrink-0">職種:</span>
        <button class="jf active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-job="all">すべて</button>
        <button class="jf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-job="eng">エンジニア</button>
        <button class="jf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-job="biz">ビジネス職</button>
        <button class="jf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-job="non">非エンジニア</button>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[11px] text-gray-400 w-16 shrink-0">難易度:</span>
        <button class="lf active px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-lv="all">すべて</button>
        <button class="lf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-lv="初級">初級</button>
        <button class="lf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-lv="中級">中級</button>
        <button class="lf px-2.5 py-1 rounded-full text-[11px] border cursor-pointer transition-all" data-lv="上級">上級</button>
      </div>
    </div>

    <div id="case-list" class="grid grid-cols-1 gap-3"></div>
    <div id="no-results" class="hidden text-center py-16"><p class="text-sm text-gray-400">条件に一致する事例がありません</p></div>
  </main>
</Layout>

<style>
  .cf.active,.jf.active,.lf.active { background-color: var(--color-primary-bg); color: var(--color-primary); border-color: var(--color-primary-border); }
  .cf:not(.active),.jf:not(.active),.lf:not(.active) { background-color: white; color: #6b7280; border-color: var(--color-base-border); }
  .cf:not(.active):hover,.jf:not(.active):hover,.lf:not(.active):hover { background-color: #f9fafb; }
</style>

<script>
const D=[
// 業務自動化
{t:"税理士事務所の自動仕訳処理",job:"non",cat:"auto",lv:"中級",before:"60社分の仕訳処理に毎日5時間",how:"MCP×5外部サービス連携、CLAUDE.mdに仕訳ルール定義、毎晩21時に自動実行",after:"5時間→50分（83%削減）",pct:"83",tags:["MCP","CLAUDE.md","Custom Commands"],src:"税理士事務所（個人）",link:"/tips"},
{t:"営業のExcel月次集計を93%削減",job:"biz",cat:"auto",lv:"初級",before:"月次集計に平均3.2時間",how:"Claude Codeに集計ルールを指示してスクリプト自動生成",after:"3.2時間→14分（93%削減）",pct:"93",tags:["基本操作"],src:"一般企業・営業部門",link:"/track/business"},
{t:"CS返信作成時間を80%削減",job:"biz",cat:"auto",lv:"初級",before:"1通の返信作成に15分",how:"問い合わせ内容を自動分類し返信ドラフトを自動生成",after:"15分→3分（80%削減）、月間60時間削減",pct:"80",tags:["基本操作"],src:"EC企業・CS部門",link:"/track/business"},
{t:"経理の請求書確認を87%削減",job:"biz",cat:"auto",lv:"初級",before:"請求書確認に毎月4.5時間",how:"請求書データの読み取り・照合・差異検出を自動化",after:"4.5時間→35分（87%削減）",pct:"87",tags:["基本操作"],src:"一般企業・経理部門",link:"/track/business"},
