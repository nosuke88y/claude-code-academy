{t:"HooksでQAチェック工数40%削減",job:"eng",cat:"dev",lv:"中級",before:"QAチェック（フォーマット・lint・テスト）に工数過大",how:"Hooksでファイル保存時にフォーマッター自動実行、コミット前lint設定",after:"QAチェック工数40%削減",pct:"40",tags:["Hooks"],src:"企業開発チーム",link:"/track/engineer"},
{t:"テスト自動生成で95%カバレッジ・バグ70%減",job:"eng",cat:"dev",lv:"中級",before:"テストカバレッジ40%、バグの見落とし多い",how:"テストコード自動生成でエッジケースも網羅的にカバー",after:"カバレッジ40%→95%、本番バグ70%減少",pct:"70",tags:["基本操作"],src:"開発チーム",link:"/track/engineer"},
{t:"Firecracker社で生産性10倍達成",job:"eng",cat:"dev",lv:"中級",before:"AI非使用時の開発生産性に限界",how:"約50名規模で全社導入、開発プロセス全体にAI支援を組み込み",after:"AI非使用時比で10倍以上の生産性向上",pct:"90",tags:["基本操作","Custom Commands"],src:"Firecracker（約50名）",link:"/track/engineer"},
{t:"CS学生がSaaSを3日で構築",job:"eng",cat:"dev",lv:"中級",before:"認証・決済・AI統合を含むSaaS構築に数週間〜数ヶ月",how:"Claude Codeで全機能を自律実装、MCPでDB・API接続",after:"3日間で完全なSaaSを完成（10倍以上の速度）",pct:"90",tags:["MCP"],src:"CS学生（個人）",link:"/track/engineer"},
{t:"請求書管理MVPを1日・$3.65で構築",job:"eng",cat:"dev",lv:"中級",before:"MVP開発に数週間の見込み",how:"Claude Code + MCP（PostgreSQL、メール等）でDB〜メールテストまで一気通貫",after:"1日で完成、API費用わずか$3.65",pct:"95",tags:["MCP"],src:"エンジニア（個人）",link:"/track/engineer"},
// データ分析
{t:"広告分析を3〜5時間→7分に短縮",job:"biz",cat:"data",lv:"中級",before:"広告パフォーマンスの集計・分析・レポートに3〜5時間",how:"BigQuery/GA4をMCP接続し広告データの自動集計・分析・レポート生成",after:"3〜5時間→体感7分（約97%削減）",pct:"97",tags:["MCP"],src:"マーケター（Rimo）",link:"/track/business"},
{t:"マーケティング分析レポート95%短縮",job:"biz",cat:"data",lv:"初級",before:"分析レポート作成・更新に半日（約4時間）",how:"データ集計・可視化・レポート生成を自動化",after:"半日→約3分（95%短縮）",pct:"95",tags:["基本操作"],src:"マーケティングアナリスト",link:"/track/business"},
{t:"経理レポート作成を6時間→12分に短縮",job:"biz",cat:"data",lv:"初級",before:"月次財務レポートの集計・整形に6時間",how:"スプレッドシート上でAIがデータ集計・分析・レポート整形を自動化",after:"6時間→12分（97%短縮）",pct:"97",tags:["基本操作"],src:"経理・財務担当者",link:"/track/business"},
{t:"7時間の自律作業で99.9%精度達成",job:"eng",cat:"data",lv:"上級",before:"複雑なデータ処理に人手で数日、ミスのリスクも高い",how:"自律モードで複雑なデータ処理を委任",after:"7時間で完了、数値精度99.9%",pct:"95",tags:["基本操作"],src:"データエンジニア",link:"/track/engineer"},
// コンテンツ作成
{t:"マーケターが事業KPIを4ヶ月で300%成長",job:"non",cat:"content",lv:"中級",before:"広告データ集計30分、クリエイティブ制作を少人数で対応",how:"定型作業を自動化。データ集計→分析→打ち手提案まで一気通貫",after:"広告集計30分→1-2分、主要KPI4ヶ月で300%成長、外注費ゼロ",pct:"97",tags:["Custom Commands"],src:"スマートバンク（マーケター）",link:"/track/business"},
{t:"営業提案書の作成時間を78%削減",job:"biz",cat:"content",lv:"中級",before:"提案書作成に平均4.2時間、月間220時間の工数",how:"テンプレートをSkillsに登録し顧客情報入力で提案書を自動生成",after:"4.2時間→45分、月間220時間→47時間（78%削減）",pct:"78",tags:["Skills","Custom Commands"],src:"IT/コンサル企業・営業部門",link:"/track/business"},
{t:"提案書5分・LP30分で完成",job:"non",cat:"content",lv:"中級",before:"提案書やLP制作に多大な時間（小規模企業）",how:"構成・デザイン・コーディングを一気通貫で自動生成",after:"提案書5分、LP30分で完成（96%削減）",pct:"96",tags:["基本操作"],src:"小規模IT企業",link:"/track/business"},
{t:"1人で全マーケティングチャネルを運用",job:"non",cat:"content",lv:"上級",before:"検索広告・SNS・メールマーケ・SEOを複数人で担当",how:"広告コピー生成をサブエージェントで並列処理、FigmaプラグインやカスタムMCPを自作",after:"1名で全チャンネル運用可能、広告コピー生産量10倍",pct:"90",tags:["MCP","Custom Commands","Skills"],src:"Anthropic社内マーケチーム",link:"/tips"},
