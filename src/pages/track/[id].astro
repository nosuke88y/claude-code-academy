---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';

interface TrackData {
  title: string;
  sub: string;
}

export function getStaticPaths() {
  const tracks: Record<string, TrackData> = {
    business: { title: "ビジネス職コース", sub: "業務効率化 → ノーコード自動化まで" },
    engineer: { title: "エンジニアコース", sub: "開発ワークフロー → CI/CD統合まで" },
  };

  return Object.entries(tracks).map(([id, data]) => ({
    params: { id },
    props: { track: data },
  }));
}

const { id } = Astro.params;
const { track } = Astro.props as { track: TrackData };
---

<Layout title={`${track.title} — Claude Code Academy`}>
  <Sidebar currentTrack={id!} currentPage="home" />

  <main class="ml-[260px] p-8 min-h-screen">
    <div class="flex items-center justify-between mb-7">
      <div>
        <h1 class="text-[22px] font-semibold text-gray-900">{track.title}</h1>
        <p class="text-sm text-gray-400 mt-1">{track.sub}</p>
      </div>
    </div>

    <div class="flex flex-col items-center justify-center py-24">
      <div class="text-6xl mb-6">🚧</div>
      <h2 class="text-xl font-semibold text-gray-900 mb-2">コンテンツ準備中</h2>
      <p class="text-sm text-gray-400 mb-6">「{track.title}」は現在制作中です。もうしばらくお待ちください。</p>
      <a href="/" class="px-6 py-2.5 bg-primary text-white rounded-lg text-sm font-medium no-underline hover:bg-primary-dark transition-colors">
        初心者コースに戻る
      </a>
    </div>
  </main>
</Layout>
